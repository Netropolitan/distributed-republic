---
// Reusable, mobile-safe three.js decorative object used INSTEAD of images.
// Props:
//   type    - 'ring' | 'tree' | 'village' | 'nodes' | 'hearth'
//   height  - css height of the canvas area
//   label   - accessible label describing the object
const { type = 'ring', height = '440px', label = 'Animated decorative object' } = Astro.props;
---

<figure class="three-object" data-three={type} style={`--three-h:${height}`} role="img" aria-label={label}>
  <div class="three-object__mount" aria-hidden="true"></div>
  <img class="three-object__fallback" src="/dr-mark.svg" alt="" aria-hidden="true" width="120" height="120" />
</figure>

<style>
  .three-object { position: relative; margin: 0; width: 100%; height: var(--three-h); }
  .three-object__mount { position: absolute; inset: 0; }
  .three-object__mount canvas { display: block; width: 100% !important; height: 100% !important; }
  .three-object__fallback {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 38%; max-width: 180px; height: auto; opacity: 0.92;
  }
  .three-object.is-live .three-object__fallback { display: none; }
</style>

<script>
  import * as THREE from 'three';

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const DPR = Math.min(window.devicePixelRatio || 1, 1.75);

  const FOREST = '#0D7555', FOREST2 = '#065F46', SAGE = '#A7D8C4', CREAM = '#FAF8F4';
  const AMBER = '#E8A23D', GLOW = '#F2C078', BARK = '#6B4F3A', GRASS = '#3E7D5F', ROOF = '#7A3B2E';
  const HEAD = '#E9DCC5';
  const BODY_COLORS = ['#065F46', '#0D7555', '#059669', '#7A3B2E', '#46618A'];
  const std = (color: string) => new THREE.MeshStandardMaterial({ color, flatShading: true });

  // ── Reusable low-poly pieces ──
  function makeFigure(scale = 1, bodyColor = FOREST2) {
    const g = new THREE.Group();
    // Rounded capsule torso + warm head reads as a person, not a cone.
    const torso = new THREE.Mesh(new THREE.CapsuleGeometry(0.13, 0.3, 4, 10), std(bodyColor));
    torso.position.y = 0.32;
    const head = new THREE.Mesh(new THREE.SphereGeometry(0.115, 14, 14), std(HEAD));
    head.position.y = 0.62;
    g.add(torso, head);
    g.scale.setScalar(scale);
    return g;
  }
  function makeTree(scale = 1) {
    const g = new THREE.Group();
    const trunk = new THREE.Mesh(new THREE.CylinderGeometry(0.07, 0.1, 0.55, 6), std(BARK));
    trunk.position.y = 0.27;
    // Two-tuft crown in brighter sage-emerald so it reads on both the dark
    // forest section and the light cards.
    const crown = new THREE.Group();
    const c1 = new THREE.Mesh(new THREE.IcosahedronGeometry(0.42, 0), std('#3DA882'));
    c1.position.y = 0.8;
    const c2 = new THREE.Mesh(new THREE.IcosahedronGeometry(0.27, 0), std('#63CBA2'));
    c2.position.set(0.13, 1.05, 0.05);
    crown.add(c1, c2);
    g.add(trunk, crown);
    g.scale.setScalar(scale);
    return g;
  }
  function makeCabin() {
    const g = new THREE.Group();
    const wall = new THREE.Mesh(new THREE.BoxGeometry(0.5, 0.4, 0.5), std(CREAM));
    wall.position.y = 0.2;
    const roof = new THREE.Mesh(new THREE.ConeGeometry(0.43, 0.3, 4), std(ROOF));
    roof.position.y = 0.56; roof.rotation.y = Math.PI / 4;
    // Front face (+z): a door centred at the base with a lit window either side.
    const door = new THREE.Mesh(new THREE.PlaneGeometry(0.15, 0.24), std('#5C3A2E'));
    door.position.set(0, 0.12, 0.251);
    const winMat = new THREE.MeshBasicMaterial({ color: GLOW });
    const w1 = new THREE.Mesh(new THREE.PlaneGeometry(0.1, 0.1), winMat); w1.position.set(-0.15, 0.28, 0.251);
    const w2 = new THREE.Mesh(new THREE.PlaneGeometry(0.1, 0.1), winMat); w2.position.set(0.15, 0.28, 0.251);
    g.add(wall, roof, door, w1, w2);
    return g;
  }
  function fire(group: THREE.Group, y = 0.25) {
    const flame = new THREE.Mesh(new THREE.ConeGeometry(0.22, 0.5, 6), new THREE.MeshBasicMaterial({ color: AMBER }));
    flame.position.y = y;
    const glow = new THREE.Mesh(new THREE.SphereGeometry(0.6, 14, 14), new THREE.MeshBasicMaterial({ color: GLOW, transparent: true, opacity: 0.18 }));
    glow.position.y = y;
    group.add(flame, glow);
    return (t: number) => { flame.scale.set(1, 1 + Math.sin(t * 3) * 0.09, 1); glow.scale.setScalar(1 + Math.sin(t * 2.2) * 0.06); };
  }

  // ── Builders: each returns { update, camera } ──
  function buildRing(group: THREE.Group, small: boolean) {
    const N = small ? 7 : 9, R = 1.55;
    const figs: { f: THREE.Group; ph: number }[] = [];
    for (let i = 0; i < N; i++) {
      const a = (i / N) * Math.PI * 2;
      const f = makeFigure(1);
      f.position.set(Math.cos(a) * R, 0, Math.sin(a) * R);
      f.rotation.y = -a + Math.PI / 2;
      group.add(f); figs.push({ f, ph: i });
    }
    const fireUp = fire(group, 0.25);
    group.position.y = -0.55;
    return {
      update: (t: number) => { group.rotation.y = t * 0.12; figs.forEach(({ f, ph }) => { f.position.y = Math.sin(t * 1.4 + ph) * 0.045; }); fireUp(t); },
      camera: { pos: [0, 2.6, 5.2] as const, look: [0, 0, 0] as const },
    };
  }

  function buildTree(group: THREE.Group) {
    const tree = makeTree(2.1); group.add(tree);
    const canopy = tree.children[1] as THREE.Mesh;
    const flies: { m: THREE.Mesh; r: number; a: number; y: number; sp: number }[] = [];
    for (let i = 0; i < 8; i++) {
      const m = new THREE.Mesh(new THREE.SphereGeometry(0.035, 6, 6), new THREE.MeshBasicMaterial({ color: GLOW, transparent: true }));
      group.add(m);
      flies.push({ m, r: 1.1 + Math.random() * 1.1, a: Math.random() * 6.28, y: 0.8 + Math.random() * 1.9, sp: 0.3 + Math.random() * 0.4 });
    }
    group.position.y = -1.25;
    return {
      update: (t: number) => {
        canopy.rotation.z = Math.sin(t * 0.7) * 0.06; canopy.position.x = Math.sin(t * 0.7) * 0.03;
        flies.forEach((o) => {
          o.m.position.set(Math.cos(o.a + t * o.sp) * o.r, o.y + Math.sin(t * o.sp * 2 + o.a) * 0.18, Math.sin(o.a + t * o.sp) * o.r);
          (o.m.material as THREE.MeshBasicMaterial).opacity = 0.45 + Math.sin(t * 3 + o.a) * 0.45;
        });
      },
      camera: { pos: [0, 0.95, 5.9] as const, look: [0, 0.5, 0] as const },
    };
  }

  function buildVillage(group: THREE.Group, small: boolean) {
    const green = new THREE.Mesh(new THREE.CircleGeometry(1.8, 30), std(GRASS));
    green.rotation.x = -Math.PI / 2; group.add(green);
    const n = small ? 3 : 4;
    for (let i = 0; i < n; i++) {
      const a = (i / n) * Math.PI * 2 + 0.4;
      const c = makeCabin(); c.position.set(Math.cos(a) * 1.3, 0, Math.sin(a) * 1.3); c.rotation.y = -a - Math.PI / 2; c.scale.setScalar(0.9);
      group.add(c);
    }
    // Trees sit in the gaps between houses (same ring), clearing the inner
    // green so the inward-facing doors are visible.
    for (let i = 0; i < n; i++) { const a = (i / n) * Math.PI * 2 + 0.4 + Math.PI / n; const tr = makeTree(0.62); tr.position.set(Math.cos(a) * 1.3, 0, Math.sin(a) * 1.3); group.add(tr); }
    group.position.y = -0.6;
    return {
      update: (t: number) => { group.rotation.y = t * 0.1; },
      camera: { pos: [0, 3.4, 4.8] as const, look: [0, 0, 0] as const },
    };
  }

  function buildNodes(group: THREE.Group, small: boolean) {
    const N = small ? 26 : 42, R = 1.6;
    const phi = Math.PI * (3 - Math.sqrt(5));
    const pts: THREE.Vector3[] = [];
    for (let i = 0; i < N; i++) { const y = 1 - (i / (N - 1)) * 2; const r = Math.sqrt(1 - y * y); const t = phi * i; pts.push(new THREE.Vector3(Math.cos(t) * r, y, Math.sin(t) * r).multiplyScalar(R)); }
    const dotGeo = new THREE.SphereGeometry(0.055, 12, 12); const dotMat = new THREE.MeshBasicMaterial({ color: FOREST });
    for (const p of pts) { const m = new THREE.Mesh(dotGeo, dotMat); m.position.copy(p); group.add(m); }
    const lp: number[] = [];
    for (let i = 0; i < pts.length; i++) { const ns = pts.map((q, j) => ({ j, d: pts[i].distanceTo(q) })).filter((o) => o.j !== i).sort((a, b) => a.d - b.d).slice(0, 2); for (const { j } of ns) lp.push(pts[i].x, pts[i].y, pts[i].z, pts[j].x, pts[j].y, pts[j].z); }
    const lg = new THREE.BufferGeometry(); lg.setAttribute('position', new THREE.Float32BufferAttribute(lp, 3));
    group.add(new THREE.LineSegments(lg, new THREE.LineBasicMaterial({ color: SAGE, transparent: true, opacity: 0.5 })));
    return { update: (t: number) => { group.rotation.y = t * 0.18; group.rotation.x = Math.sin(t * 0.12) * 0.12; }, camera: { pos: [0, 0, 6] as const, look: [0, 0, 0] as const } };
  }

  function buildHearth(group: THREE.Group) {
    const fireUp = fire(group, 0.4);
    for (let i = 0; i < 5; i++) { const log = new THREE.Mesh(new THREE.CylinderGeometry(0.09, 0.09, 1.4, 8), std(FOREST)); log.rotation.z = Math.PI / 2; log.rotation.y = (i / 5) * Math.PI; log.position.y = -0.5; group.add(log); }
    return { update: (t: number) => { group.rotation.y = t * 0.15; fireUp(t); }, camera: { pos: [0, 0, 6] as const, look: [0, 0, 0] as const } };
  }

  function init(el: HTMLElement) {
    const mount = el.querySelector<HTMLElement>('.three-object__mount');
    if (!mount) return;
    let renderer: THREE.WebGLRenderer;
    try { renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true, powerPreference: 'low-power' }); } catch (e) { return; }
    const w = mount.clientWidth || 400, h = mount.clientHeight || 400;
    renderer.setPixelRatio(DPR); renderer.setSize(w, h, false); mount.appendChild(renderer.domElement);

    const scene = new THREE.Scene();
    scene.add(new THREE.AmbientLight(0xffffff, 0.9));
    const key = new THREE.DirectionalLight(0xfff2dd, 1.1); key.position.set(3, 5, 4); scene.add(key);
    const camera = new THREE.PerspectiveCamera(42, w / h, 0.1, 100);
    const group = new THREE.Group(); scene.add(group);

    const small = window.matchMedia('(max-width: 700px)').matches;
    const type = el.getAttribute('data-three');
    const builders: Record<string, () => any> = {
      ring: () => buildRing(group, small), tree: () => buildTree(group), village: () => buildVillage(group, small),
      nodes: () => buildNodes(group, small), hearth: () => buildHearth(group),
    };
    const built = (builders[type || 'ring'] || builders.ring)();
    const update = built.update;
    camera.position.set(...built.camera.pos); camera.lookAt(new THREE.Vector3(...built.camera.look));
    el.classList.add('is-live');

    function resize() { const cw = mount!.clientWidth, ch = mount!.clientHeight; if (!cw || !ch) return; camera.aspect = cw / ch; camera.updateProjectionMatrix(); renderer.setSize(cw, ch, false); }
    window.addEventListener('resize', () => requestAnimationFrame(resize), { passive: true });

    const clock = new THREE.Clock();
    let raf = 0, running = false;
    function frame() { update(clock.getElapsedTime()); renderer.render(scene, camera); raf = requestAnimationFrame(frame); }
    function start() { if (!running) { running = true; clock.start(); raf = requestAnimationFrame(frame); } }
    function stop() { running = false; cancelAnimationFrame(raf); }

    if (reduced) { update(0.8); renderer.render(scene, camera); }
    else {
      const io = new IntersectionObserver((es) => { for (const e of es) e.isIntersecting ? start() : stop(); }, { threshold: 0.05 });
      io.observe(el);
      document.addEventListener('visibilitychange', () => { document.hidden ? stop() : start(); });
    }
  }

  function boot() { document.querySelectorAll<HTMLElement>('.three-object[data-three]').forEach((el) => { if (!el.dataset.inited) { el.dataset.inited = '1'; init(el); } }); }
  if (document.readyState !== 'loading') boot(); else document.addEventListener('DOMContentLoaded', boot);
</script>
