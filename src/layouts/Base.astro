---
import '../styles/theme.css';
import EmailSignup from '../components/EmailSignup.astro';
const {
  title = 'Distributed Republic',
  description = 'Building technologically advanced, networked communities for a different way of living.',
  noindex = false,
  hideSignupCta = false,
  home = false, // homepage manages its own spacing (full-viewport tour stages)
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og.png', Astro.site).href;
const nav = [
  { href: '/', label: 'Home' },
  { href: '/about/', label: 'About' },
  { href: '/events/', label: 'Events' },
  { href: '/blog/', label: 'Blog' },
  { href: '/resources/', label: 'Resources' },
  { href: '/contact/', label: 'Contact' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta property="og:site_name" content="Distributed Republic" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,400;0,500;0,600;0,700;0,800&family=Spline+Sans+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/axs/axs-widget.css" />
</head>
<body>
  <header class="site-header">
    <div class="nav">
      <a class="brand" href="/" aria-label="Distributed Republic home">
        <img src="/dr-mark.svg" alt="" width="32" height="32" />
        <b>Distributed Republic</b>
      </a>
      <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">&#9776;</button>
      <nav class="nav-links" aria-label="Primary">
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      </nav>
    </div>
  </header>

  <main id="main" class={home ? '' : 'page'}>
    <slot />
  </main>

  {!hideSignupCta && (
    <section class="cta-band" aria-label="Keep up to date">
      <div class="inner">
        <span class="step-tag">A journey, not a sign-up</span>
        <h2>Follow along</h2>
        <p style="margin-bottom:24px">Occasional notes on the project as it takes shape. No names, just your email.</p>
        <EmailSignup tone="light" heading="" blurb="" />
      </div>
    </section>
  )}

  <footer class="site-footer">
    <div class="container">
      <div class="foot-grid">
        <div>
          <a class="brand" href="/" style="margin-bottom:14px">
            <img src="/dr-mark.svg" alt="" width="30" height="30" style="filter:brightness(0) invert(1)" />
            <b style="color:var(--cream)">Distributed Republic</b>
          </a>
          <p style="max-width:42ch">Networked communities under an anarchic-agreements model. Campus, Curation, Rituals, Contribution.</p>
        </div>
        <div>
          <h3>Explore</h3>
          <div style="margin:6px 0"><a href="/about/">About</a></div>
          <div style="margin:6px 0"><a href="/events/">Events</a></div>
          <div style="margin:6px 0"><a href="/blog/">Blog</a></div>
          <div style="margin:6px 0"><a href="/resources/">Resources</a></div>
        </div>
        <div>
          <h3>Get involved</h3>
          <div style="margin:6px 0"><a href="/#follow">Follow along</a></div>
          <div style="margin:6px 0"><a href="/contact/">Contact us</a></div>
        </div>
      </div>
      <div class="foot-bottom">© 2026 Distributed Republic · Community living</div>
    </div>
  </footer>

  <!-- Day / night toggle: moon by day, sun by night. Pairs with the AXS button
       below it and drives the same dark-mode preference. On the homepage the
       village scene listens for the class change and turns to night. -->
  <button id="nightToggle" type="button" aria-label="Switch between day and night" title="Day / night"></button>
  <script>
    const ICON_MOON = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
    const ICON_SUN = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4.5"/><path d="M12 2v2.5M12 19.5V22M2 12h2.5M19.5 12H22M4.6 4.6l1.8 1.8M17.6 17.6l1.8 1.8M19.4 4.6l-1.8 1.8M6.4 17.6l-1.8 1.8"/></svg>';
    const nightBtn = document.getElementById('nightToggle');
    const syncIcon = () => {
      if (nightBtn) nightBtn.innerHTML = document.documentElement.classList.contains('axs-dark-mode') ? ICON_SUN : ICON_MOON;
    };
    syncIcon();
    new MutationObserver(syncIcon).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    nightBtn?.addEventListener('click', () => {
      const on = !document.documentElement.classList.contains('axs-dark-mode');
      document.documentElement.classList.toggle('axs-dark-mode', on);
      // keep the AXS widget's saved preference in step
      try {
        const p = JSON.parse(localStorage.getItem('axs-prefs') || '{}');
        p.darkMode = on;
        localStorage.setItem('axs-prefs', JSON.stringify(p));
      } catch (e) { /* private mode */ }
    });
  </script>

  <script src="/axs/axs-widget.js" defer></script>
  <script>
    const t = document.querySelector('.nav-toggle');
    const links = document.querySelector('.nav-links');
    t?.addEventListener('click', () => {
      const open = links?.classList.toggle('open');
      t.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
  </script>
</body>
</html>
