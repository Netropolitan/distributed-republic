    }
    gParty.userData.butterflies = butterflies;
  })();

  // ---------- villagers : little folk wandering freely, walking around things ----------
  const gFolk = stageGroup();
  const folk = [];
  {
    const folkCols = [0x065F46, 0xD88C6A, 0xF4CE6A, 0x4E6E8E];
    // each villager roams a home patch; patches keep them off the river, lake and rim
    const zones = [
      { cx: 0, cz: 2, R: 5.0, sx: 0, sz: 2, sp: 0.55 },          // the village green
      { cx: -5.4, cz: -3.2, R: 2.8, sx: -5.4, sz: -2.2, sp: 0.4 }, // the allotment
      { cx: -4.5, cz: 9, R: 4.5, sx: -5.0, sz: 8.4, sp: 0.5 },   // the gathering green
      { cx: 9.3, cz: 11.2, R: 2.4, sx: 9.6, sz: 10.2, sp: 0.4 }, // the far hamlet
    ];
    const walkableAt = (x, z) =>
      Math.hypot(x, z) < 16
      && Math.hypot(x - LAKE.x, z - LAKE.z) > LAKE.r + 0.5
      && RIVER_PTS.every(([rx, rz]) => Math.hypot(x - rx, z - rz) > 1.35);
    // the whole straight path must clear every obstacle circle, not just the endpoints
    const segClear = (ax, az, bx, bz) => obstacles.every((o) => {
      const dx = bx - ax, dz = bz - az;
      const L2 = dx * dx + dz * dz || 1e-6;
      const u = Math.max(0, Math.min(1, ((o.x - ax) * dx + (o.z - az) * dz) / L2));
      return Math.hypot(ax + dx * u - o.x, az + dz * u - o.z) > o.r + 0.2;
    });
    const pathOk = (ax, az, bx, bz) => {
      if (!walkableAt(bx, bz) || !segClear(ax, az, bx, bz)) return false;
      for (let s = 0.1; s < 1; s += 0.1) if (!walkableAt(ax + (bx - ax) * s, az + (bz - az) * s)) return false;
      return true;
    };
    gFolk.userData.pickTarget = function (v) {
      for (let i = 0; i < 24; i++) {
        const a = Math.random() * Math.PI * 2;
        const rr = 0.6 + Math.random() * (v.zone.R - 0.6);
        const x = v.zone.cx + Math.cos(a) * rr, z = v.zone.cz + Math.sin(a) * rr;
        if (pathOk(v.x, v.z, x, z)) { v.tx = x; v.tz = z; return true; }
      }
      return false;
    };
    // find a spot between two patches where both villagers can walk to stand a step apart
    gFolk.userData.tryMeet = function (va, vb) {
      for (let i = 0; i < 16; i++) {
        const x = (va.zone.cx + vb.zone.cx) / 2 + (Math.random() - 0.5) * 3;
        const z = (va.zone.cz + vb.zone.cz) / 2 + (Math.random() - 0.5) * 3;
        const dx = vb.x - va.x, dz = vb.z - va.z;
        const L = Math.hypot(dx, dz) || 1;
        const ox = (dx / L) * 0.19, oz = (dz / L) * 0.19;
        if (pathOk(va.x, va.z, x - ox, z - oz) && pathOk(vb.x, vb.z, x + ox, z + oz)) {
          return { ax: x - ox, az: z - oz, bx: x + ox, bz: z + oz };
        }
      }
      return null;
    };
    zones.forEach((zone, i) => {
      const p = new THREE.Group();
      const body = new THREE.Mesh(new THREE.CylinderGeometry(0.07, 0.11, 0.3, 6),
        new THREE.MeshStandardMaterial({ color: folkCols[i], flatShading: true, roughness: 1 }));
      body.position.y = 0.15; p.add(body);
      const head = new THREE.Mesh(new THREE.SphereGeometry(0.08, 7, 6), skinMat);
      head.position.y = 0.38; p.add(head);
      p.userData = { head, zone, sp: zone.sp, x: zone.sx, z: zone.sz, tx: zone.sx, tz: zone.sz, idle: 0.5 + i * 0.8, ph: rand() * Math.PI * 2, meeting: false };
      p.position.set(zone.sx, hAt(zone.sx, zone.sz), zone.sz);
      gFolk.add(p); folk.push(p);
    });
  }
  // eight more villagers who only come out for the evening fire (hidden by day)
  const fireGuests = [];
  {
    const guestCols = [0xA7D8C4, 0xC9A24B, 0x67A86B, 0xB85C48, 0x3E7CB8, 0xF2BFA4, 0x065F46, 0xD88C6A];
    for (let i = 0; i < 8; i++) {
      const p = new THREE.Group();
      const body = new THREE.Mesh(new THREE.CylinderGeometry(0.07, 0.11, 0.3, 6),
        new THREE.MeshStandardMaterial({ color: guestCols[i], flatShading: true, roughness: 1 }));
      body.position.y = 0.15; p.add(body);
      const head = new THREE.Mesh(new THREE.SphereGeometry(0.08, 7, 6), skinMat);
      head.position.y = 0.38; p.add(head);
      p.scale.setScalar(0.92 + rand() * 0.14);
      p.userData = { head };
      p.visible = false;
      gFolk.add(p); fireGuests.push(p);
    }
  }
  const fireCircle = [...folk, ...fireGuests]; // 12 seats: three along each of the four logs
  // every so often two neighbours walk over and have a chat (the hamlet villager
  // is across the lake, so meetups happen between the three western patches)
  const meet = { phase: 'wait', timer: 9, a: 0, b: 0 };

  // ---------- clouds ----------
  const cloudMat = new THREE.MeshBasicMaterial({ color: 0xFFFFFF, transparent: true, opacity: 0.95 });
  const cloudShadowMat = new THREE.MeshBasicMaterial({ color: 0x23402F, transparent: true, opacity: 0.07, depthWrite: false });
  const clouds = [];
  for (let i = 0; i < 6; i++) {
    const g = new THREE.Group();
    for (let k = 0; k < 4; k++) {
      const m = new THREE.Mesh(new THREE.IcosahedronGeometry(1.0 + rand() * 0.9, 1), cloudMat);
      m.position.set(k * 1.5 - 2.2 + rand() * 0.8, rand() * 0.5, rand() * 0.8);
      m.scale.y = 0.5; g.add(m);
    }
    const a = rand() * Math.PI * 2;
    // clouds stay over the village (small radius, high up) so they never
    // drift near the camera and loom huge when parallax shifts the view
    g.position.set(Math.cos(a) * (10 + rand() * 12), 26 + rand() * 8, Math.sin(a) * (10 + rand() * 12));
    g.userData.a = a; g.userData.r = Math.hypot(g.position.x, g.position.z); g.userData.h = g.position.y;
    // a soft shadow sweeps the lawn beneath each cloud
    const sh = new THREE.Mesh(new THREE.CircleGeometry(2.4, 14), cloudShadowMat);
    sh.rotation.x = -Math.PI / 2;
    sh.scale.x = 1.5;
    table.add(sh);
    g.userData.shadow = sh;
    scene.add(g); clouds.push(g);
  }

  // ---------- smoke : firepit + hall chimney ----------
  function smokePlume(x, y, z, n, scale0, rise) {
    const puffs = [];
    for (let i = 0; i < n; i++) {
      const mat = new THREE.MeshBasicMaterial({ color: 0xBDB7AA, transparent: true, opacity: 0, depthWrite: false });
      const m = new THREE.Mesh(new THREE.IcosahedronGeometry(1, 0), mat);
      const life = 2.6 + rand() * 1.4;
      m.userData = { x, y, z, age: rand() * life, life, drift: rand() * Math.PI * 2, scale0, rise };
      table.add(m); puffs.push(m);
    }
    return puffs;
  }
  const smoke = prefersReduced ? [] : [
    ...smokePlume(-8.2, hAt(-8.2, 6.6) + 0.75, 6.6, 5, 0.16, 1.9),
    ...smokePlume(1.05, hAt(0, -2) + 3.1, -2, 4, 0.12, 1.5),
  ];

  // ---------- night mode : the dark-mode toggle turns the village to dusk ----------
  let seed2 = 41;
  const rand2 = () => { seed2 = (seed2 * 16807) % 2147483647; return seed2 / 2147483647; };
  const N_STARS = 260;
  const starGeo = new THREE.BufferGeometry();
  const starPos = new Float32Array(N_STARS * 3);
  for (let i = 0; i < N_STARS; i++) {
    const a = rand2() * Math.PI * 2, e = 0.15 + rand2() * 1.2, r = 150;
    starPos[i * 3] = Math.cos(a) * Math.cos(e) * r;
    starPos[i * 3 + 1] = Math.sin(e) * r;
    starPos[i * 3 + 2] = Math.sin(a) * Math.cos(e) * r;
  }
  starGeo.setAttribute('position', new THREE.BufferAttribute(starPos, 3));
  const starMat = new THREE.PointsMaterial({ color: 0xEAF4F0, size: 1.4, sizeAttenuation: false, transparent: true, opacity: 0.85 });
  const stars = new THREE.Points(starGeo, starMat);
  stars.visible = false;
  scene.add(stars);
  // fireflies in the southern woods (night only)
  const FF = 22;
  const ffGeo = new THREE.BufferGeometry();
  const ffPos = new Float32Array(FF * 3), ffSeed = new Float32Array(FF);
  for (let i = 0; i < FF; i++) {
    ffPos[i * 3] = -2 + (rand2() - 0.5) * 7;
    ffPos[i * 3 + 1] = 1 + rand2() * 3.2;
    ffPos[i * 3 + 2] = -11.5 + (rand2() - 0.5) * 6;
    ffSeed[i] = rand2() * 100;
  }
  ffGeo.setAttribute('position', new THREE.BufferAttribute(ffPos, 3));
  const ffMat = new THREE.PointsMaterial({ color: 0xFFE9A0, size: 0.28, transparent: true, opacity: 0.9, sizeAttenuation: true });
  const fireflies = new THREE.Points(ffGeo, ffMat);
  fireflies.visible = false;
  table.add(fireflies);
  // subtle embers drifting up from the firepit (night only)
  const EMB = 16;
  const embY = hAt(-8.2, 6.6);
  const embGeo = new THREE.BufferGeometry();
  const embPos = new Float32Array(EMB * 3), embSeed = new Float32Array(EMB);
  for (let i = 0; i < EMB; i++) {
    embPos[i * 3] = -8.2 + (rand2() - 0.5) * 0.5;
    embPos[i * 3 + 1] = embY + 0.3 + rand2() * 1.8;
    embPos[i * 3 + 2] = 6.6 + (rand2() - 0.5) * 0.5;
    embSeed[i] = rand2() * 100;
  }
  embGeo.setAttribute('position', new THREE.BufferAttribute(embPos, 3));
  const embMat = new THREE.PointsMaterial({ color: 0xFFA85C, size: 0.09, transparent: true, opacity: 0.8, sizeAttenuation: true });
  const embers = new THREE.Points(embGeo, embMat);
  embers.visible = false;
  table.add(embers);

  // at night the villagers gather on the log seats around the fire;
  // by day they go back to wandering from wherever they left off
  let folkAtFire = false;
  function setFolkFire(on) {
    folkAtFire = on;
    if (meet.phase !== 'wait') {
      for (const idx of [meet.a, meet.b]) {
        folk[idx].userData.meeting = false;
        folk[idx].userData.head.position.y = 0.38;
      }
      meet.phase = 'wait'; meet.timer = 12;
    }
    const gy = hAt(-8.2, 6.6);
    fireCircle.forEach((p, s) => {
      const v = p.userData;
      if (on) {
        // seat s -> log (s % 4), slot along the log (-1, 0, +1)
        const a = ((s % 4) / 4) * Math.PI * 2 + Math.PI / 4;
        const slot = Math.floor(s / 4) - 1;
        const cx = -8.2 + Math.cos(a) * 1.5, cz = 6.6 + Math.sin(a) * 1.5;
        const fx = cx + -Math.sin(a) * 0.38 * slot, fz = cz + Math.cos(a) * 0.38 * slot;
        p.position.set(fx, gy + 0.15, fz); // settled onto the log, legs tucked
        p.rotation.y = Math.atan2(-(6.6 - fz), -8.2 - fx); // facing the flames
        p.rotation.z = 0;
        p.visible = true;
        if (v.zone) v.meeting = false;
      } else if (v.zone) {
        v.idle = 0.6 + (s % 4) * 0.7;
        p.position.set(v.x, hAt(v.x, v.z), v.z);
      } else {
        p.visible = false; // the evening guests head home at dawn
      }
    });
  }

  // dusk falls as a tween, not a switch: the toggle sets a target and the
  // animate loop eases nightT toward it, lerping every colour and light
  const dayCol = { bg: new THREE.Color(0xF3EEE1), hemi: new THREE.Color(0xFFFBEA), ground: new THREE.Color(0xCBDCC4), sun: new THREE.Color(0xFFF2CE), cloud: new THREE.Color(0xFFFFFF) };
  const nightCol = { bg: new THREE.Color(0x07211B), hemi: new THREE.Color(0x2E4A40), ground: new THREE.Color(0x0A1F18), sun: new THREE.Color(0x9FC4D8) /* moonlight */, cloud: new THREE.Color(0x3A4A44) };
  windowMat.emissive.set(0xFFC97A);
  windowMat.emissiveIntensity = 0;
  const mix = (d, n, k) => d + (n - d) * k;
  let nightTarget = 0, nightT = -1; // -1 = before first apply
  function applyNight(k) {
    scene.background.lerpColors(dayCol.bg, nightCol.bg, k);
    hemi.color.lerpColors(dayCol.hemi, nightCol.hemi, k);
    hemi.groundColor.lerpColors(dayCol.ground, nightCol.ground, k);
    hemi.intensity = mix(1.2, 0.35, k);
    sun.color.lerpColors(dayCol.sun, nightCol.sun, k);
    sun.intensity = mix(1.4, 0.5, k);
    fillL.intensity = mix(0.45, 0.12, k);
    windowMat.emissiveIntensity = 0.85 * k;
    cloudMat.color.lerpColors(dayCol.cloud, nightCol.cloud, k);
    cloudMat.opacity = mix(0.95, 0.4, k);
    stars.visible = k > 0.02;
    starMat.opacity = 0.85 * k;
    fireflies.visible = k > 0.3;
    embers.visible = k > 0.3;
    gParty.userData.butterflies.forEach((b) => { b.visible = k < 0.5; }); // butterflies roost at night
    if ((k >= 0.5) !== folkAtFire) setFolkFire(k >= 0.5); // dusk: everyone gathers at the fire
  }
  function setNight(on) {
    nightTarget = on ? 1 : 0;
    if (nightT < 0 || prefersReduced) { nightT = nightTarget; applyNight(nightT); }
  }
  new MutationObserver(() => setNight(document.documentElement.classList.contains('axs-dark-mode')))
    .observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  setNight(document.documentElement.classList.contains('axs-dark-mode'));
  // inline !important so the AXS dark-mode catch-all can never paint over the village
  document.querySelectorAll('main, main .stage, main .wrap, #scene, .steps, .steps .step, .steps .lbl').forEach((el) =>
    el.style.setProperty('background-color', 'transparent', 'important'));

  // ---------- scroll-driven guided tour ----------
  const sections = [...document.querySelectorAll('main .stage')];
  const stepEls = [...document.querySelectorAll('.steps .step')];
  const FOCI = [
    { tx: 0,    ty: 1.2, tz: 0,    r: 44, h: 24, side:  1 },   // s0 hero · whole village
    { tx: 0,    ty: 1.0, tz: 0,    r: 33, h: 16, side: -1 },   // s1 idea · closer overview
    { tx: -2.6, ty: 1.2, tz: -2.4, r: 19, h: 10.5, side:  1 }, // s2 hall + allotment
    { tx: -2,   ty: 0.9, tz: 3,    r: 17, h: 9.5, side: -1 },  // s3 homes round the green
    { tx: -5.4, ty: 0.9, tz: -3.6, r: 14, h: 9,  side:  1 },   // s35 co-op · the growing beds
    { tx: -3.6, ty: 0.8, tz: 9.6,  r: 15, h: 8.5, side: -1 },  // s4 the gathering green
    { tx: 5.0,  ty: 0.8, tz: 4.5,  r: 23, h: 14, side:  1 },   // s5 the crossing · both hamlets + boat in frame
    { tx: -5.4, ty: 1.0, tz: -8.8, r: 13, h: 8,  side: -1 },   // s6 watermill + river
    { tx: 0,    ty: 1.2, tz: 0,    r: 40, h: 21, side:  1 },   // s7 follow · pull back out
  ];

  function tourProgress() {
    const vh = window.innerHeight;
    let p = 0;
    for (const sec of sections) {
      const r = sec.getBoundingClientRect();
      p += THREE.MathUtils.clamp((vh / 2 - r.top) / r.height, 0, 1);
    }
    return THREE.MathUtils.clamp(p - 0.5, 0, FOCI.length - 1);
  }
  const ease = (u) => u * u * (3 - 2 * u);

  let mx = 0, my = 0, smx = 0, smy = 0;
  window.addEventListener('pointermove', (e) => {
    mx = e.clientX / window.innerWidth - 0.5;
    my = e.clientY / window.innerHeight - 0.5;
  });

  let smoothP = 0;
  // one-time establishing shot: swoop down into the hero framing on first load
  // (skipped for reduced motion, deep-link hashes, or reloads mid-page)
  const doIntro = !prefersReduced && window.scrollY < window.innerHeight * 0.3 && !location.hash;
  let introT = doIntro ? 0 : 1;
  const camTarget = new THREE.Vector3();
  const camRight = new THREE.Vector3();
  const up = new THREE.Vector3(0, 1, 0);

  const clock = new THREE.Clock();
  let t = 0;
  function animate() {
    requestAnimationFrame(animate);
    const dt = Math.min(clock.getDelta(), 0.05);
    t += dt;
    // exp(-dt·k) smoothing is frame-rate independent (per-frame factors run 2x fast at 120Hz)
    if (!prefersReduced) { const pk = 1 - Math.exp(-dt * 1.8); smx += (mx - smx) * pk; smy += (my - smy) * pk; }

    smoothP += (tourProgress() - smoothP) * (prefersReduced ? 1 : 1 - Math.exp(-dt * 3.3));

    if (Math.abs(nightTarget - nightT) > 0.001) {
      nightT += (nightTarget - nightT) * (1 - Math.exp(-dt * 2.4));
      if (Math.abs(nightTarget - nightT) <= 0.001) nightT = nightTarget;
      applyNight(nightT);
    }
    const i0 = Math.floor(smoothP);
    const i1 = Math.min(i0 + 1, FOCI.length - 1);
    const f = ease(smoothP - i0);
    const a = FOCI[i0], b = FOCI[i1];
    const L = (k) => a[k] + (b[k] - a[k]) * f;

    const wide = window.innerWidth > 920;
    let ang = 0.7 + smoothP * 0.55 + (prefersReduced ? 0 : t * 0.014);
    let rad = L('r'), hgt = L('h');
    // crane up and over between stops: clears the trees and reads like a drone move
    hgt += Math.sin(f * Math.PI) * Math.min(6, Math.hypot(b.tx - a.tx, b.tz - a.tz) * 0.35 + Math.abs(b.r - a.r) * 0.18 + 1.2);
    if (introT < 1) {
      introT = Math.min(1, introT + dt / 3.0);
      const iK = 1 - Math.pow(1 - introT, 3); // cubic ease-out descent
      rad *= 1 + 1.1 * (1 - iK);
      hgt += 26 * (1 - iK);
      ang -= 0.9 * (1 - iK);
    }
    camTarget.set(L('tx'), L('ty'), L('tz'));
    camera.position.set(
      camTarget.x + Math.cos(ang) * rad + smx * 3,
      hgt + smy * -2,
      camTarget.z + Math.sin(ang) * rad
    );
    if (wide) {
      camRight.subVectors(camTarget, camera.position).cross(up).normalize();
      const shift = L('side') * rad * -0.3;
      camera.position.addScaledVector(camRight, shift);
      camTarget.addScaledVector(camRight, shift);
    }
    camera.lookAt(camTarget);

    // life in the model
    if (gMill.userData.wheel) gMill.userData.wheel.rotation.z = t * 0.7;
    if (!prefersReduced) {
      // lake ripple (gentle, so the waterline laps rather than waves)
      const lkp = lakeGeo.attributes.position;
      for (let i = 0; i < lkp.count; i++) {
        const x = lakeBase[i * 3], z = lakeBase[i * 3 + 2];
        lkp.setY(i, Math.sin(x * 1.4 + t * 0.9) * 0.022 + Math.sin(z * 1.7 - t * 0.7) * 0.018);
      }
      lkp.needsUpdate = true;
      lakeGeo.computeVertexNormals();
      // foam drifting downstream
      for (const m of gMill.userData.flow) {
        const u = m.userData.u = (m.userData.u + dt * m.userData.sp) % 1;
        const p = gMill.userData.curve.getPointAt(u);
        const tng = gMill.userData.curve.getTangentAt(u);
        const w = (0.45 + u * 0.45) * 0.6 * m.userData.off;
        let fy = hAt(p.x, p.z) + 0.1;
        const fdp = Math.hypot(p.x + 13.6, p.z + 5.8);
        if (fdp < 1.9) fy = Math.min(fy, 0.105); // match the river's dip under the pool
        m.position.set(p.x - tng.z * w, fy, p.z + tng.x * w);
      }
      // fire flicker
      const fl = gGather.userData.flames;
      fl[0].scale.y = 1 + Math.sin(t * 7.3) * 0.1 + Math.sin(t * 13.7) * 0.05;
      fl[1].scale.y = 1 + Math.sin(t * 9.1 + 1.2) * 0.13;
      // smoke puffs: rise, swell, fade, respawn (fainter at night, embers take over)
      for (const m of smoke) {
        const s = m.userData;
        s.age += dt;
        if (s.age > s.life) { s.age = 0; s.drift = Math.random() * Math.PI * 2; }
        const u = s.age / s.life;
        m.position.set(
          s.x + Math.sin(t * 0.6 + s.drift) * 0.1 + u * 0.5,
          s.y + u * s.rise,
          s.z + Math.cos(t * 0.5 + s.drift) * 0.08
        );
        m.scale.setScalar(s.scale0 * (0.6 + u * 1.8));
        m.material.opacity = Math.sin(Math.min(u * 3, 1) * Math.PI / 2) * 0.32 * (1 - u) * (1 - nightT * 0.45);
      }
    }
    if (gGather.userData.fireLight) {
      gGather.userData.fireLight.intensity = mix(1.4, 2.6, Math.max(nightT, 0))
        * (prefersReduced ? 1 : 1 + Math.sin(t * 11) * 0.05 + Math.sin(t * 5.3 + 2) * 0.05);
    }
    gParty.userData.butterflies.forEach((b) => {
      if (!b.visible) return;
      const u = b.userData;
      const ba = t * u.speed + u.ph;
      b.position.set(-2.5 + Math.cos(ba) * u.rx, hAt(-2.5, 10.2) + u.oy + Math.sin(ba * 1.9) * 0.3, 10.2 + Math.sin(ba) * u.rz);
      b.rotation.y = -ba;
      const fl = Math.sin(t * 9 + u.flap) * 0.75;
      u.w1.rotation.y = fl; u.w2.rotation.y = -fl;
    });
    const boat = gNetwork.userData.boat;
    if (boat && !prefersReduced) {
      // 56s day on the water, with a fishing stop mid-lake
      const cyc = t % 56;
      let bu = 0, bmode = 'rest', bdir = 1;
      for (const [l0, l1, u0, u1, m] of gNetwork.userData.legs) {
        if (cyc >= l0 && cyc < l1) {
          bu = u0 + (u1 - u0) * ease((cyc - l0) / (l1 - l0));
          bmode = m; bdir = u1 >= u0 ? 1 : -1;
          break;
        }
      }
      const rp = gNetwork.userData.route.getPointAt(bu);
      boat.position.set(rp.x, 0.1 + Math.sin(t * 0.9) * 0.035, rp.z);
      boat.rotation.z = Math.sin(t * 0.7) * 0.04;
      const rowing = bmode === 'row';
      if (rowing) {
        const rtg = gNetwork.userData.route.getTangentAt(Math.min(Math.max(bu, 0.01), 0.99));
        gNetwork.userData.heading = Math.atan2(-rtg.z * bdir, rtg.x * bdir);
      }
      // the hull turns toward its heading instead of snapping (shortest way round)
      const dh = Math.atan2(Math.sin(gNetwork.userData.heading - boat.rotation.y), Math.cos(gNetwork.userData.heading - boat.rotation.y));
      boat.rotation.y += dh * (1 - Math.exp(-dt * 2));
      // oars blend between full stroke and shipped-aft rather than switching
      gNetwork.userData.rowMix += ((rowing ? 1 : 0) - gNetwork.userData.rowMix) * (1 - Math.exp(-dt * 2.2));
      const rm = gNetwork.userData.rowMix;
      gNetwork.userData.oars.forEach((o, oi) => {
        const side = oi ? -1 : 1;
        // a real stroke, not an orbit: blade dipped while pulling aft,
        // lifted while swinging forward (lift follows the sweep's direction).
        // the starboard oar is a scale-mirrored copy, so its yaw must be
        // negated (side factor) for both oars to sweep the SAME way together
        const th = t * 2.2;
        const lift = Math.max(0, Math.cos(th)); // cos>0 = moving forward = blade out
        o.rotation.y = side * (-0.85 * (1 - rm) + Math.sin(th) * 0.45 * rm);
        o.rotation.x = side * (0.2 * (1 - rm) + (0.55 - 0.35 * lift) * rm);
      });
      // the rod raises and the line fades in, easing in and out of the fishing stop
      gNetwork.userData.fishMix += ((bmode === 'fish' ? 1 : 0) - gNetwork.userData.fishMix) * (1 - Math.exp(-dt * 1.8));
      const fm = gNetwork.userData.fishMix;
      const tk = gNetwork.userData.tackle.userData;
      tk.rodG.rotation.z = 1.45 - 0.55 * fm;
      tk.lineMat.opacity = fm;
      tk.bobMat.opacity = fm;
      if (fm > 0.02) tk.bobber.position.y = 0.02 + Math.sin(t * 2.2) * 0.025;
    }
    if (folkAtFire && !prefersReduced) {
      // fireside: seated, swapping stories — staggered nods around the circle
      fireCircle.forEach((p, i) => {
        p.userData.head.position.y = 0.38 + Math.max(0, Math.sin(t * 1.8 + i * 1.7)) * 0.02;
        p.rotation.z = Math.sin(t * 1.1 + i) * 0.03;
      });
    }
    if (!folkAtFire && !prefersReduced) {
      meet.timer -= dt;
      if (meet.phase === 'wait' && meet.timer <= 0) {
        const pairs = [[0, 1], [0, 2], [1, 2]];
        const [ia, ib] = pairs[(Math.random() * pairs.length) | 0];
        const spot = gFolk.userData.tryMeet(folk[ia].userData, folk[ib].userData);
        if (spot) {
          meet.phase = 'gather'; meet.a = ia; meet.b = ib;
          const va = folk[ia].userData, vb = folk[ib].userData;
          va.meeting = true; va.idle = 0; va.tx = spot.ax; va.tz = spot.az;
          vb.meeting = true; vb.idle = 0; vb.tx = spot.bx; vb.tz = spot.bz;
        } else meet.timer = 6; // no clear ground today, try again shortly
      }
      if (meet.phase === 'gather') {
        const va = folk[meet.a].userData, vb = folk[meet.b].userData;
        if (Math.hypot(va.tx - va.x, va.tz - va.z) < 0.09 && Math.hypot(vb.tx - vb.x, vb.tz - vb.z) < 0.09) {
          meet.phase = 'chat'; meet.timer = 4 + Math.random() * 4;
          folk[meet.a].rotation.y = Math.atan2(-(vb.z - va.z), vb.x - va.x);
          folk[meet.b].rotation.y = Math.atan2(-(va.z - vb.z), va.x - vb.x);
        }
      }
      if (meet.phase === 'chat') {
        // they take turns nodding while they talk
        for (const [idx, ph] of [[meet.a, 0], [meet.b, Math.PI]]) {
          const pp = folk[idx];
          pp.userData.head.position.y = 0.38 + Math.max(0, Math.sin(t * 3.2 + ph)) * 0.025;
          pp.rotation.z = Math.sin(t * 1.6 + ph) * 0.04;
        }
        if (meet.timer <= 0) {
          meet.phase = 'wait'; meet.timer = 18 + Math.random() * 25;
          for (const idx of [meet.a, meet.b]) {
            folk[idx].userData.meeting = false;
            folk[idx].userData.idle = 0.8 + Math.random() * 1.5;
            folk[idx].userData.head.position.y = 0.38;
          }
        }
      }
      for (const p of folk) {
        const v = p.userData;
        if (v.idle > 0) {
          v.idle -= dt;
          p.rotation.z = Math.sin(t * 1.2 + v.ph) * 0.03; // standing, looking about
          if (v.idle <= 0 && !gFolk.userData.pickTarget(v)) v.idle = 1.5 + Math.random() * 2;
        } else {
          const dx = v.tx - v.x, dz = v.tz - v.z;
          const dist = Math.hypot(dx, dz);
          if (dist < 0.07) {
            if (!v.meeting) v.idle = 1 + Math.random() * 5; // meeters wait for their friend
          } else {
            const step = Math.min(dist, v.sp * dt);
            v.x += (dx / dist) * step; v.z += (dz / dist) * step;
            p.rotation.y = Math.atan2(-dz, dx);
            p.rotation.z = Math.sin(t * 7 + v.ph) * 0.05;
            p.position.set(v.x, hAt(v.x, v.z) + Math.abs(Math.sin(t * 7 + v.ph)) * 0.02, v.z);
          }
        }
      }
    }
    if (fireflies.visible) {
      const fp = ffGeo.attributes.position;
      for (let i = 0; i < FF; i++) {
        fp.array[i * 3] += Math.cos(t * 0.35 + ffSeed[i]) * 0.006;
        fp.array[i * 3 + 1] += Math.sin(t * 0.6 + ffSeed[i] * 1.7) * 0.005;
      }
      fp.needsUpdate = true;
      ffMat.opacity = (0.5 + Math.sin(t * 1.4) * 0.35) * nightT;
    }
    if (embers.visible) {
      const ep = embGeo.attributes.position;
      for (let i = 0; i < EMB; i++) {
        ep.array[i * 3 + 1] += dt * (0.22 + (embSeed[i] % 1) * 0.3);
        ep.array[i * 3] += Math.sin(t * 1.6 + embSeed[i]) * 0.004;
        ep.array[i * 3 + 2] += Math.cos(t * 1.3 + embSeed[i] * 2) * 0.004;
        if (ep.array[i * 3 + 1] > embY + 2.6) {
          ep.array[i * 3] = -8.2 + (Math.random() - 0.5) * 0.4;
          ep.array[i * 3 + 1] = embY + 0.3;
          ep.array[i * 3 + 2] = 6.6 + (Math.random() - 0.5) * 0.4;
        }
      }
      ep.needsUpdate = true;
      embMat.opacity = (0.55 + Math.sin(t * 6.5) * 0.2) * nightT;
    }
    clouds.forEach((c) => {
      c.userData.a += dt * 0.012;
      c.position.set(Math.cos(c.userData.a) * c.userData.r, c.userData.h, Math.sin(c.userData.a) * c.userData.r);
      const sh = c.userData.shadow;
      const onDisc = Math.hypot(c.position.x, c.position.z) < 15.5;
      sh.visible = onDisc;
      if (onDisc) sh.position.set(c.position.x, Math.max(hAt(c.position.x, c.position.z), 0.1) + 0.08, c.position.z);
    });
    cloudShadowMat.opacity = 0.07 * (1 - nightT * 0.7);

    renderer.render(scene, camera);
  }
  animate();

  window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  });

  // reveals + tour rail state
  const io = new IntersectionObserver((es) => {
    es.forEach((e) => {
      if (!e.isIntersecting) return;
      e.target.querySelectorAll('.reveal').forEach((el) => el.classList.add('in'));
      const idx = sections.indexOf(e.target);
      stepEls.forEach((s, i) => {
        s.classList.toggle('on', i === idx);
        s.classList.toggle('done', i < idx);
        // inline colours so the dark-mode catch-all can't black out the dots
        s.querySelector('.dot').style.setProperty(
          'background-color',
          i === idx ? '#065F46' : i < idx ? '#A7D8C4' : 'transparent',
          'important'
        );
      });
    });
  }, { threshold: 0.4 });
  sections.forEach((s) => io.observe(s));
</script>
