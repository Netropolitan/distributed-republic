---
import Base from '../layouts/Base.astro';
import EmailSignup from '../components/EmailSignup.astro';
---
<Base title="Contact · Distributed Republic" description="Get in touch with Distributed Republic, whether you are a prospective co-founder, resident, collaborator, or know of a place that might be a fit.">
  <section class="container section">
    <div class="hero" style="padding-top:0">
      <div>
        <p class="eyebrow">Contact</p>
        <h1>Start a conversation.</h1>
        <p class="lead">Co-founder, prospective resident, collaborator, or just curious. Tell us a little about you and what draws you to community living, and we will be in touch.</p>
        <p>You can also reach us about places: land, buildings, or existing communities that might be a fit.</p>
      </div>

      <form id="dr-contact" class="card" novalidate>
        <div style="display:grid;gap:16px">
          <label>Name
            <input name="name" required autocomplete="name" />
          </label>
          <label>Email
            <input name="email" type="email" required autocomplete="email" />
          </label>
          <label>Message
            <textarea name="message" rows="5" required></textarea>
          </label>
          <!-- Honeypot: bots fill this; humans never see it -->
          <input type="text" name="company" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px" />
          <button class="btn btn--primary" type="submit">Send message</button>
          <p id="dr-contact-status" role="status" aria-live="polite" style="margin:0;min-height:1.2em"></p>
        </div>
      </form>
    </div>
  </section>

  <section class="section section--cream2">
    <div class="container" style="max-width:560px">
      <EmailSignup tone="light" heading="Not ready to reach out?" blurb="Leave your email and we will keep you up to date as the project takes shape. No names, no spam." />
    </div>
  </section>

  <style>
    #dr-contact label { display:block; font-size:14px; font-weight:600; color:var(--charcoal); }
    #dr-contact input, #dr-contact textarea {
      width:100%; margin-top:6px; padding:12px 14px; font-size:16px; font-family:var(--body);
      border:1px solid var(--line); border-radius:10px; background:var(--cream); color:var(--charcoal);
    }
    #dr-contact input:focus, #dr-contact textarea:focus { outline:2px solid var(--decorative); border-color:var(--decorative); }
  </style>

  <script>
    // Posts to the DR contact webhook (Tailscale Funnel route /dr-contact),
    // which the native automation engine turns into a Brew table row + A-Mail.
    // Endpoint is wired when the backend Contact feature ships (Phase 1).
    const CONTACT_ENDPOINT = ''; // e.g. https://<funnel-host>/dr-contact
    const form = document.getElementById('dr-contact') as HTMLFormElement | null;
    const status = document.getElementById('dr-contact-status');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) { form.reportValidity(); return; }
      const data = Object.fromEntries(new FormData(form).entries());
      if ((data as any).company) return; // honeypot tripped
      if (!CONTACT_ENDPOINT) {
        if (status) status.textContent = 'Thanks. The contact form is not connected yet, so please email jamie@bykovbrett.net for now.';
        return;
      }
      if (status) status.textContent = 'Sending…';
      try {
        const res = await fetch(CONTACT_ENDPOINT, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
        if (!res.ok) throw new Error(String(res.status));
        form.reset();
        if (status) status.textContent = 'Thank you. We will be in touch soon.';
      } catch (err) {
        if (status) status.textContent = 'Something went wrong. Please email jamie@bykovbrett.net.';
      }
    });
  </script>
</Base>
