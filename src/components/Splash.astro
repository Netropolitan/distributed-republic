---
// Entry splash: overlays the page with the approved dusk-lakeside three.js scene
// (public/dr-splash.html in an iframe). Click / scroll / key to enter; the iframe
// postMessages the parent, which fades the overlay out. Shows once per session,
// and can be replayed via the house button (dr-open-splash event / #open-splash).
---
<div id="dr-splash" class="dr-splash" role="dialog" aria-label="Welcome to Distributed Republic">
  <iframe id="dr-splash-frame" src="/dr-splash.html" title="Distributed Republic intro" loading="eager"></iframe>
  <button id="dr-splash-skip" class="dr-splash__skip" type="button">Skip intro</button>
</div>

<style>
  .dr-splash { position: fixed; inset: 0; z-index: 9999; background: #0b1f1a; opacity: 1; transition: opacity 1s ease; }
  .dr-splash.is-leaving { opacity: 0; pointer-events: none; }
  .dr-splash iframe { width: 100%; height: 100%; border: 0; display: block; }
  .dr-splash__skip {
    position: fixed; top: 16px; right: 16px; z-index: 10000;
    background: rgba(0,0,0,0.28); color: #FAF8F4; border: 1px solid rgba(255,255,255,0.45);
    border-radius: 999px; padding: 8px 16px; font: 600 13px Inter, sans-serif; cursor: pointer;
  }
  .dr-splash__skip:hover { background: rgba(0,0,0,0.45); }
</style>

<!-- Before paint: if seen this session (and not an explicit replay), hide instantly. -->
<script is:inline>
  try {
    var openReq = location.hash === '#open-splash';
    if (sessionStorage.getItem('dr-splash-seen') && !openReq) {
      var s = document.getElementById('dr-splash'); if (s) s.style.display = 'none';
    } else {
      document.documentElement.style.overflow = 'hidden';
    }
  } catch (e) {}
</script>

<script>
  const el = document.getElementById('dr-splash');
  const frame = document.getElementById('dr-splash-frame') as HTMLIFrameElement | null;
  function openSplash() {
    if (!el || !frame) return;
    el.dataset.done = '';
    el.classList.remove('is-leaving');
    el.style.display = 'block';
    frame.src = '/dr-splash.html'; // reload so the scene + prompt restart fresh
    document.documentElement.style.overflow = 'hidden';
  }
  function dismiss() {
    if (!el || el.dataset.done === '1') return;
    el.dataset.done = '1';
    el.classList.add('is-leaving');
    try { sessionStorage.setItem('dr-splash-seen', '1'); } catch (e) {}
    document.documentElement.style.overflow = '';
    setTimeout(() => { el.style.display = 'none'; if (frame) frame.src = 'about:blank'; }, 1100);
  }
  window.addEventListener('message', (e) => { if (e.data === 'dr-splash-enter') dismiss(); });
  window.addEventListener('dr-open-splash', openSplash);
  document.getElementById('dr-splash-skip')?.addEventListener('click', dismiss);
  // Explicit replay when arriving from another page's house button.
  if (location.hash === '#open-splash') { history.replaceState(null, '', location.pathname); openSplash(); }
</script>
