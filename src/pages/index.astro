---
import Base from '../layouts/Base.astro';
import EmailSignup from '../components/EmailSignup.astro';
import { getCollection } from 'astro:content';

// Latest real posts for the blog tour stop (empty array is handled gracefully)
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
const fmt = (d: Date) => d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' });
---
<Base
  title="Distributed Republic · Community living"
  description="We explore and build networked communities under an anarchic-agreements model: shared places, shared work, and the agreements we make together. Scroll the village."
  home={true}
  hideSignupCta={true}
>
  <div id="scene" aria-hidden="true"></div>

  <nav class="steps" aria-label="Tour stops">
    <a class="step" href="#s0"><span class="dot"></span><span class="lbl">The village</span></a>
    <a class="step" href="#s1"><span class="dot"></span><span class="lbl">The idea</span></a>
    <a class="step" href="#s2"><span class="dot"></span><span class="lbl">The commons</span></a>
    <a class="step" href="#s3"><span class="dot"></span><span class="lbl">The homes</span></a>
    <a class="step" href="#s35"><span class="dot"></span><span class="lbl">The co-op</span></a>
    <a class="step" href="#s4"><span class="dot"></span><span class="lbl">Events</span></a>
    <a class="step" href="#s5"><span class="dot"></span><span class="lbl">Blog</span></a>
    <a class="step" href="#s6"><span class="dot"></span><span class="lbl">Resources</span></a>
    <a class="step" href="#follow"><span class="dot"></span><span class="lbl">Follow</span></a>
  </nav>

  <!-- S0 : welcome -->
  <section class="stage" id="s0">
    <div class="wrap">
      <div class="card reveal">
        <span class="step-tag">Stop 01 · The village</span>
        <h1>Welcome to the village.</h1>
        <p class="lead">Distributed Republic explores and builds networked communities under an anarchic-agreements model. Keep scrolling, and we will show you around.</p>
        <div class="btn-row">
          <a class="btn btn--solid" href="#s1">Take the tour</a>
          <a class="btn btn--ghost" href="#follow">Get involved</a>
        </div>
      </div>
    </div>
  </section>

  <!-- S1 : the idea -->
  <section class="stage" id="s1">
    <div class="wrap">
      <div class="card card--right reveal">
        <span class="step-tag">Stop 02 · The idea</span>
        <h2>More than a place.</h2>
        <p>Community is more than living nearby. It is real overlap in each other's lives: shared meals, holidays celebrated together, taking turns with the children. Built on friendship and trust, not just an address. The village is a support network, not a postcode.</p>
        <p>Distributed Republic is a values-led project, not a product. It is the work of Emilija and Jamie Bykov-Brett, and it is as much about helping you picture your own community living as it is about building ours.</p>
        <div class="btn-row"><a class="btn btn--ghost" href="/about/">Read the full story</a></div>
      </div>
    </div>
  </section>

  <!-- S2 : the commons -->
  <section class="stage" id="s2">
    <div class="wrap">
      <div class="card reveal">
        <span class="step-tag">Stop 03 · The commons</span>
        <h2>The commons comes first.</h2>
        <p>Shared kitchens, workshops, gardens and gathering halls: the physical and social commons where everyday life happens together. Four pillars hold it up.</p>
        <div class="chips">
          <div class="chip"><h3>Campus</h3><p>The shared spaces where everyday life happens together.</p></div>
          <div class="chip"><h3>Curation</h3><p>Who joins, how we welcome, how we share what we have.</p></div>
          <div class="chip"><h3>Rituals</h3><p>The recurring practices that turn people into community.</p></div>
          <div class="chip"><h3>Contribution</h3><p>Time, skills, care and resources; governed by everyone.</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- S3 : the homes -->
  <section class="stage" id="s3">
    <div class="wrap">
      <div class="card card--right reveal">
        <span class="step-tag">Stop 04 · The homes</span>
        <h2>Households, close by choice.</h2>
        <p>A handful of households living closely, sharing meals, work and a co-op. Participation is encouraged, autonomy more so. How a community governs itself is written together, as a collective agreement, never handed down.</p>
      </div>
    </div>
  </section>

  <!-- S3.5 : the co-op -->
  <section class="stage" id="s35">
    <div class="wrap">
      <div class="card reveal">
        <span class="step-tag">Stop 05 · The co-op</span>
        <h2>Stronger, together.</h2>
        <p>A shared venture, a cooperative, can hold a community together: a retreat space, co-working, events, or working the land, with members sharing in the running and the rewards. Households linked this way are far more resilient when things get hard.</p>
        <p>We take inspiration from the cooperative tradition, including Mondragon, where a network of member-owned businesses grew from a single community.</p>
      </div>
    </div>
  </section>

  <!-- S4 : the gathering = events -->
  <section class="stage" id="s4">
    <div class="wrap">
      <div class="card card--right reveal" style="max-width:500px">
        <span class="step-tag">Stop 06 · The gathering</span>
        <h2>Events.</h2>
        <p>Open days, shared meals, work weekends, and conversations about community living. This is where we meet, in person and online.</p>
        <div class="list-empty">
          <p>Our first gatherings are being planned. <a href="/#follow">Follow along</a> to be invited, or <a href="/contact/">tell us you would like to come</a>.</p>
        </div>
        <a class="see-all" href="/events/">All events →</a>
      </div>
    </div>
  </section>

  <!-- S5 : the network = blog -->
  <section class="stage" id="s5">
    <div class="wrap">
      <div class="card reveal" style="max-width:500px">
        <span class="step-tag">Stop 07 · The network</span>
        <h2>Blog: notes from the journey.</h2>
        <p>One village becomes two, then a network, each keeping its own character. We write down what we learn along the way.</p>
        {posts.length > 0 ? (
          <div class="list">
            {posts.map((post) => (
              <a href={`/blog/${post.id}/`}>
                <span class="when">{fmt(post.data.pubDate)}</span>
                <span><h3>{post.data.title}</h3><p>{post.data.description}</p></span>
                <span class="go">→</span>
              </a>
            ))}
          </div>
        ) : (
          <div class="list-empty"><p>The first notes are being written.</p></div>
        )}
        <a class="see-all" href="/blog/">All posts →</a>
      </div>
    </div>
  </section>

  <!-- S6 : the mill = resources -->
  <section class="stage" id="s6">
    <div class="wrap">
      <div class="card card--right reveal" style="max-width:500px">
        <span class="step-tag">Stop 08 · The mill</span>
        <h2>Resources.</h2>
        <p>Reading, guides, and tools we have found useful in thinking about community living, governance, and the commons.</p>
        <div class="list-empty">
          <p>We are putting together our first guides. <a href="/contact/">Ask us</a> if there is something specific you would like.</p>
        </div>
        <a class="see-all" href="/resources/">All resources →</a>
      </div>
    </div>
  </section>

  <!-- S7 : follow -->
  <section class="stage" id="follow">
    <div class="wrap">
      <div class="card reveal" style="max-width:520px">
        <span class="step-tag">Stop 09 · Your place</span>
        <h2>Picture your own community living.</h2>
        <p>This is a space to imagine the way you would want to live, and to start the conversations that make it real. We are on this journey ourselves, and this is for anyone on a similar one. Some come along for the whole ride, some just want to follow the story.</p>
        <EmailSignup tone="light" heading="" blurb="" />
      </div>
    </div>
  </section>
</Base>

<style is:global>
  /* ---------- homepage tour layout ---------- */
  #scene { position: fixed; inset: 0; z-index: 0; }
  main#main { position: relative; z-index: 10; }
  /* the canvas lives INSIDE main here, so each stage must stack above it */
  .stage { position: relative; z-index: 2; min-height: 100vh; display: flex; align-items: center; padding: 110px 0; }
  .stage .wrap { width: 100%; max-width: var(--maxw); margin: 0 auto; padding: 0 var(--gutter); }
  .card--right { margin-left: auto; }
  .stage .card { max-width: 450px; }

  /* tour stop rail */
  .steps {
    position: fixed; left: 26px; top: 50%; transform: translateY(-50%); z-index: 40;
    display: flex; flex-direction: column; gap: 4px;
  }
  .steps .step { display: flex; align-items: center; gap: 10px; padding: 6px 0; text-decoration: none; }
  .steps .dot {
    width: 12px; height: 12px; border: 2px solid var(--forest-dark); border-radius: 3px;
    background: transparent; transition: background .3s, transform .3s;
  }
  .steps .lbl {
    font-family: var(--mono); font-size: 11px; letter-spacing: 1.6px; text-transform: uppercase;
    color: var(--body-grey); opacity: 0; transform: translateX(-6px); transition: opacity .3s, transform .3s;
  }
  .steps .step.done .dot { background: var(--sage); }
  .steps .step.on .dot { background: var(--forest); transform: rotate(45deg); }
  .steps .step.on .lbl, .steps .step:hover .lbl { opacity: 1; transform: none; }
  @media (max-width: 920px) { .steps { display: none; } }

  /* AXS dark mode: keep the scroll layers transparent so the night village
     shows through (the widget's catch-all forces opaque backgrounds).
     The doubled :not(#axs-widget-root) matches the widget rule's specificity. */
  html.axs-dark-mode > body main#main:not(#axs-widget-root):not(#axs-widget-root),
  html.axs-dark-mode > body section.stage:not(#axs-widget-root):not(#axs-widget-root),
  html.axs-dark-mode > body .stage .wrap:not(#axs-widget-root):not(#axs-widget-root),
  html.axs-dark-mode > body #scene:not(#axs-widget-root):not(#axs-widget-root) {
    background-color: transparent !important;
  }
</style>

<script>
  import * as THREE from 'three';

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const mount = document.getElementById('scene');
  let renderer;
  try {
    renderer = new THREE.WebGLRenderer({ antialias: true });
  } catch (err) {
    // no WebGL: a calm gradient stands in for the village and the content stays readable
    if (mount) mount.style.background = 'linear-gradient(180deg, #F3EEE1 0%, #DCEEE5 60%, #BFDCC8 100%)';
    throw err;
  }
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.75));
  renderer.setSize(window.innerWidth, window.innerHeight);
  mount.appendChild(renderer.domElement);

  const scene = new THREE.Scene();
  scene.background = new THREE.Color(0xF3EEE1);

  const camera = new THREE.PerspectiveCamera(38, window.innerWidth / window.innerHeight, 0.1, 300);

  const hemi = new THREE.HemisphereLight(0xFFFBEA, 0xCBDCC4, 1.2);
  scene.add(hemi);
  const sun = new THREE.DirectionalLight(0xFFF2CE, 1.4);
  sun.position.set(30, 50, 20);
  scene.add(sun);
  const fillL = new THREE.DirectionalLight(0xCFE6DC, 0.45);
  fillL.position.set(-30, 20, -20);
  scene.add(fillL);

  let seed = 17;
  const rand = () => { seed = (seed * 16807) % 2147483647; return seed / 2147483647; };

  // ---------- the turntable ----------
  const table = new THREE.Group();
  scene.add(table);

  const base = new THREE.Mesh(
    new THREE.CylinderGeometry(17, 18, 2.6, 48),
    new THREE.MeshStandardMaterial({ color: 0xEDE5D0, flatShading: true, roughness: 1 })
  );
  // top cap at -0.2: safely below the lawn everywhere outside the lake bowl
  base.position.y = -1.5;
  table.add(base);
  const baseRim = new THREE.Mesh(
    new THREE.TorusGeometry(17.45, 0.22, 10, 64),
    new THREE.MeshStandardMaterial({ color: 0x065F46, roughness: 0.7 })
  );
  baseRim.rotation.x = Math.PI / 2;
  baseRim.position.y = 0.02;
  table.add(baseRim);

  // terrain height: mostly flat, two gentle rises, a mound up to the dock,
  // a carved lake basin (east third) and level ground around the spring pool
  const LAKE = { x: 9.0, z: 1, r: 7.2 };
  // the river's course (spring -> mill -> lake); shared by the mesh and the villagers' no-walk rules
  const RIVER_PTS = [[-12.6, -6.7], [-10.5, -8.6], [-7.6, -10.8], [-4.9, -10.1], [-2.6, -8.3], [-0.3, -6.5], [1.9, -5.0], [3.9, -3.7], [5.6, -2.5]];
  const obstacles = []; // {x,z,r} circles the villagers walk around, filled in as structures are built
  function hAt(x, z) {
    const r = Math.hypot(x, z);
    let y = Math.max(0, Math.cos(r * 0.12)) * 0.15
      + Math.exp(-((x + 8) ** 2 + (z + 6) ** 2) / 26) * 0.8
      + Math.exp(-((x - 2) ** 2 + (z + 11) ** 2) / 30) * 0.55
      + Math.exp(-((x - 0.2) ** 2 + (z - 0.2) ** 2) / 6) * 0.55;
    const d = Math.hypot(x - LAKE.x, z - LAKE.z);
    if (d < LAKE.r + 0.6) { const k = Math.min(1, (LAKE.r + 0.6 - d) / 2.2); y = y * (1 - k) - 0.45 * k; }
    const dp = Math.hypot(x + 13.6, z + 5.8);
    if (dp < 3.0) { const k = Math.min(1, (3.0 - dp) / 1.6); y = y * (1 - k) + 0.02 * k; }
    return y;
  }
  // displaced grid disc (a plain CircleGeometry has no interior vertices to carve)
  const topGeo = new THREE.PlaneGeometry(34, 34, 80, 80);
  topGeo.rotateX(-Math.PI / 2);
  const tpp = topGeo.attributes.position;
  for (let i = 0; i < tpp.count; i++) {
    let x = tpp.getX(i), z = tpp.getZ(i);
    const r = Math.hypot(x, z);
    if (r > 17) { const s = 17 / r; x *= s; z *= s; tpp.setX(i, x); tpp.setZ(i, z); }
    tpp.setY(i, hAt(x, z));
  }
  topGeo.computeVertexNormals();
  const lawn = new THREE.Mesh(topGeo, new THREE.MeshStandardMaterial({ color: 0x8DBE72, flatShading: true, roughness: 1 }));
  table.add(lawn);

  // ---------- the lake ----------
  // a gridded disc (not CircleGeometry) so the surface has vertices to ripple
  const lakeGeo = new THREE.PlaneGeometry(LAKE.r * 2, LAKE.r * 2, 22, 22);
  lakeGeo.rotateX(-Math.PI / 2);
  {
    const lp = lakeGeo.attributes.position;
    for (let i = 0; i < lp.count; i++) {
      const x = lp.getX(i), z = lp.getZ(i);
      const r = Math.hypot(x, z);
      if (r > LAKE.r) { const s = LAKE.r / r; lp.setX(i, x * s); lp.setZ(i, z * s); }
    }
  }
  const lakeBase = lakeGeo.attributes.position.array.slice();
  const lakeMesh = new THREE.Mesh(
    lakeGeo,
    new THREE.MeshStandardMaterial({ color: 0x8FC8D8, flatShading: true, roughness: 0.25 })
  );
  lakeMesh.position.set(LAKE.x, 0.1, LAKE.z);
  table.add(lakeMesh);
  for (let i = 0; i < 12; i++) {
    const a = (i / 12) * Math.PI * 2 + 0.3;
    const sx = LAKE.x + Math.cos(a) * (LAKE.r + 0.5), sz = LAKE.z + Math.sin(a) * (LAKE.r + 0.5);
    if (Math.hypot(sx, sz) > 16.3) continue;
    const st = new THREE.Mesh(new THREE.DodecahedronGeometry(0.16 + rand() * 0.12, 0),
      new THREE.MeshStandardMaterial({ color: 0xC8BCA2, flatShading: true, roughness: 1 }));
    st.position.set(sx, hAt(sx, sz) + 0.12, sz);
    table.add(st);
  }

  // ---------- the village ----------
  const stages = [];
  function stageGroup() { const g = new THREE.Group(); table.add(g); stages.push(g); return g; }

  const woodMat = new THREE.MeshStandardMaterial({ color: 0x9B7A56, flatShading: true, roughness: 1 });
  const wallMat = new THREE.MeshStandardMaterial({ color: 0xF2E3C8, flatShading: true, roughness: 1 });
  const roofMat = new THREE.MeshStandardMaterial({ color: 0xD88C6A, flatShading: true, roughness: 1 });
  const roofMat2 = new THREE.MeshStandardMaterial({ color: 0x065F46, flatShading: true, roughness: 1 });
  const trunkMat = new THREE.MeshStandardMaterial({ color: 0x84603F, flatShading: true, roughness: 1 });
  const skinMat = new THREE.MeshStandardMaterial({ color: 0xE8C39E, flatShading: true, roughness: 1 });
  const leafMats = [0x4F8F5C, 0x67A86B, 0x3E7B4E].map(c => new THREE.MeshStandardMaterial({ color: c, flatShading: true, roughness: 1 }));

  function tree(g, x, z, s = 1) {
    obstacles.push({ x, z, r: 0.5 * s });
    const tr = new THREE.Mesh(new THREE.CylinderGeometry(0.14, 0.2, 1, 5), trunkMat);
    const y = hAt(x, z);
    tr.position.set(x, y + 0.5 * s, z); tr.scale.setScalar(s); g.add(tr);
    const lv = new THREE.Mesh(new THREE.IcosahedronGeometry(0.85, 0), leafMats[Math.floor(rand() * 3)]);
    lv.position.set(x, y + (1 + 0.75) * s, z); lv.scale.setScalar(s); lv.scale.y *= 1.25; g.add(lv);
  }
  const doorMat = new THREE.MeshStandardMaterial({ color: 0x065F46 });
  const windowMat = new THREE.MeshStandardMaterial({ color: 0xBFDFE8, roughness: 0.2 });
  function house(g, x, z, ry = 0, s = 1, roof = roofMat) {
    obstacles.push({ x, z, r: 1.15 * s });
    const grp = new THREE.Group();
    const body = new THREE.Mesh(new THREE.BoxGeometry(1.7, 1.1, 1.3), wallMat);
    body.position.y = 0.55; grp.add(body);
    const r = new THREE.Mesh(new THREE.ConeGeometry(1.35, 0.85, 4), roof);
    r.position.y = 1.52; r.rotation.y = Math.PI / 4; r.scale.x = 1.18; grp.add(r);
    const door = new THREE.Mesh(new THREE.PlaneGeometry(0.3, 0.5), doorMat);
    door.position.set(0, 0.35, 0.66); grp.add(door);
    for (const wx of [-0.5, 0.5]) {
      const w = new THREE.Mesh(new THREE.PlaneGeometry(0.32, 0.32), windowMat);
      w.position.set(wx, 0.62, 0.66); grp.add(w);
    }
    for (const sideX of [-0.86, 0.86]) {
      const w = new THREE.Mesh(new THREE.PlaneGeometry(0.32, 0.32), windowMat);
      w.position.set(sideX, 0.6, 0); w.rotation.y = sideX > 0 ? Math.PI / 2 : -Math.PI / 2;
      grp.add(w);
    }
    grp.position.set(x, hAt(x, z), z); grp.rotation.y = ry; grp.scale.setScalar(s);
    g.add(grp);
  }

  // trees
  const gTrees = stageGroup();
  const treeSpots = [[-12, -2], [-9.2, -5.8], [-13.5, 3], [-15, -0.5], [-3, -13], [1, -13.5], [5, -12.5], [9, -11.5], [12.5, -7.5], [14.5, -6.5], [-7.5, 11], [-11, 7.5], [-5, 13.2], [0.5, 14], [4, 11.5], [4.8, 13.4]];
  treeSpots.forEach(([x, z]) => tree(gTrees, x, z, 0.8 + rand() * 0.7));

  // the commons: hall + allotment + scarecrow
  const gCommons = stageGroup();
  (function () {
    const hall = new THREE.Group();
    const body = new THREE.Mesh(new THREE.BoxGeometry(3.6, 1.7, 2.4), wallMat);
    body.position.y = 0.85; hall.add(body);
    // a true rectangular gable roof: triangle cross-section extruded along the ridge
    const gableShape = new THREE.Shape();
    gableShape.moveTo(-1.45, 0); gableShape.lineTo(1.45, 0); gableShape.lineTo(0, 1.15); gableShape.closePath();
    const roofGeo = new THREE.ExtrudeGeometry(gableShape, { depth: 4.1, bevelEnabled: false });
    roofGeo.translate(0, 0, -2.05);
    const r = new THREE.Mesh(roofGeo, roofMat2);
    r.rotation.y = Math.PI / 2;
    r.position.y = 1.7;
    hall.add(r);
    const chimney = new THREE.Mesh(new THREE.BoxGeometry(0.26, 0.55, 0.26), wallMat);
    chimney.position.set(1.05, 2.78, 0); // sunk into the ridge, poking just above it
    hall.add(chimney);
    const hallDoor = new THREE.Mesh(new THREE.PlaneGeometry(0.7, 1.0), doorMat);
    hallDoor.position.set(0, 0.5, 1.21); hall.add(hallDoor);
    for (const wx of [-1.2, 1.2]) {
      const w = new THREE.Mesh(new THREE.PlaneGeometry(0.5, 0.55), windowMat);
      w.position.set(wx, 0.95, 1.21); hall.add(w);
    }
    for (const sideX of [-1.81, 1.81]) {
      const w = new THREE.Mesh(new THREE.PlaneGeometry(0.5, 0.55), windowMat);
      w.position.set(sideX, 0.95, 0); w.rotation.y = sideX > 0 ? Math.PI / 2 : -Math.PI / 2;
      hall.add(w);
    }
    hall.position.set(0, hAt(0, -2), -2);
    gCommons.add(hall);
    obstacles.push({ x: 0, z: -2, r: 2.25 });
    // the community allotment: six varied beds and a scarecrow
    const bedMat = new THREE.MeshStandardMaterial({ color: 0x7A5B3C, flatShading: true, roughness: 1 });
    const cropCols = [0x4F8F5C, 0xF4CE6A, 0xD88C6A, 0x67A86B, 0xA7D8C4, 0x3E7B4E];
    let bi = 0;
    for (const bz of [-4.3, -3.0]) for (const bx of [-7.0, -5.4, -3.8]) {
      const bed = new THREE.Mesh(new THREE.BoxGeometry(1.3, 0.22, 0.75), bedMat);
      bed.position.set(bx, hAt(bx, bz) + 0.12, bz);
      gCommons.add(bed);
      obstacles.push({ x: bx, z: bz, r: 0.55 }); // the gardener goes round the beds, never through
      const cMat = new THREE.MeshStandardMaterial({ color: cropCols[bi++ % 6], flatShading: true, roughness: 1 });
      for (let p = 0; p < 4; p++) {
        const veg = new THREE.Mesh(new THREE.IcosahedronGeometry(0.11 + rand() * 0.05, 0), cMat);
        veg.position.set(bx - 0.45 + p * 0.3, hAt(bx, bz) + 0.3, bz + (rand() - 0.5) * 0.28);
        gCommons.add(veg);
      }
    }
    const scX = -4.2, scZ = -4.6, scY = hAt(scX, scZ);
    obstacles.push({ x: scX, z: scZ, r: 0.35 });
    const scPole = new THREE.Mesh(new THREE.CylinderGeometry(0.05, 0.05, 1.1, 5), woodMat);
    scPole.position.set(scX, scY + 0.55, scZ); gCommons.add(scPole);
    const scArm = new THREE.Mesh(new THREE.BoxGeometry(0.7, 0.06, 0.06), woodMat);
    scArm.position.set(scX, scY + 0.85, scZ); gCommons.add(scArm);
    const scHead = new THREE.Mesh(new THREE.SphereGeometry(0.14, 7, 7), wallMat);
    scHead.position.set(scX, scY + 1.12, scZ); gCommons.add(scHead);
    const scHat = new THREE.Mesh(new THREE.ConeGeometry(0.17, 0.18, 6),
      new THREE.MeshStandardMaterial({ color: 0xC9A24B, flatShading: true, roughness: 1 }));
    scHat.position.set(scX, scY + 1.28, scZ); gCommons.add(scHat);
  })();

  // homes spread around the green, none touching
  const gHomes = stageGroup();
