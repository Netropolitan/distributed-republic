    });
    // small butterflies fluttering over the green (they roost at night)
    const butterflies = [];
    const wingCols = [0xF4CE6A, 0xA7D8C4, 0xFFFFFF, 0xF2BFA4];
    for (let i = 0; i < 6; i++) {
      const b = new THREE.Group();
      const mat = new THREE.MeshBasicMaterial({ color: wingCols[i % 4], side: THREE.DoubleSide, transparent: true, opacity: 0.95 });
      const wingGeo = new THREE.CircleGeometry(0.016, 6);
