    const flow = [];
    for (let i = 0; i < 12; i++) {
      const m = new THREE.Mesh(new THREE.SphereGeometry(0.05, 5, 4), foamMat);
      m.scale.y = 0.35;
      m.userData = { u: i / 12, sp: 0.038 + (i % 3) * 0.007, off: (rand() - 0.5) * 1.1 };
      if (prefersReduced) m.visible = false;
      gMill.add(m);
      flow.push(m);
    }
    gMill.userData.flow = flow;
    gMill.userData.curve = sCurve;
    const axle = new THREE.Mesh(new THREE.BoxGeometry(2.6, 0.1, 0.1), woodMat);
    axle.position.set(-5.2, hAt(-4.5, -10.0) + 0.9, -9.0);
    axle.rotation.y = 0.96;
    gMill.add(axle);
  })();

  // celebration: string lights + butterflies over the north green
  const gParty = stageGroup();
  (function () {
    const A = [-4.4, 9.5], B = [-0.6, 10.3];
    const pts = [];
    for (let i = 0; i <= 16; i++) {
      const u = i / 16;
      const x = A[0] + (B[0] - A[0]) * u, z = A[1] + (B[1] - A[1]) * u;
      pts.push(new THREE.Vector3(x, hAt(x, z) + 2.1 - Math.sin(u * Math.PI) * 0.35, z));
    }
    const wire = new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts),
      new THREE.LineBasicMaterial({ color: 0x4D5A52 }));
    gParty.add(wire);
    pts.forEach((p, i) => {
      if (i % 2 === 0) return;
      const bulb = new THREE.Mesh(new THREE.SphereGeometry(0.09, 6, 6),
        new THREE.MeshBasicMaterial({ color: i % 4 === 1 ? 0xF4CE6A : 0xFFF3CC }));
      bulb.position.copy(p); bulb.position.y -= 0.12;
