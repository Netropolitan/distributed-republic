---
// Reusable, mobile-safe three.js decorative object used INSTEAD of images.
// Props:
//   type    - 'ring' | 'tree' | 'village' | 'nodes' | 'hearth'
//   height  - css height of the canvas area
//   label   - accessible label describing the object
const { type = 'ring', height = '440px', label = 'Animated decorative object' } = Astro.props;
---

<figure class="three-object" data-three={type} style={`--three-h:${height}`} role="img" aria-label={label}>
  <div class="three-object__mount" aria-hidden="true"></div>
  <img class="three-object__fallback" src="/dr-mark.svg" alt="" aria-hidden="true" width="120" height="120" />
</figure>

<style>
  .three-object { position: relative; margin: 0; width: 100%; max-width: 100%; height: var(--three-h); overflow: hidden; }
  .three-object__mount { position: absolute; inset: 0; overflow: hidden; }
  .three-object__mount :global(canvas) { display: block; max-width: 100%; }
  .three-object__fallback {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 38%; max-width: 180px; height: auto; opacity: 0.92;
  }
  .three-object.is-live .three-object__fallback { display: none; }
  /* Mobile: bleed full-width to the viewport edge (0 padding), cancelling the
     container's 5px gutter. Scoped here so it outspecifies the width rule above. */
  @media (max-width: 768px) {
    .three-object {
      width: calc(100% + (var(--gutter) * 2));
      max-width: none;
      margin-inline: calc(var(--gutter) * -1);
    }
  }
</style>

<script>
  import * as THREE from 'three';

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const DPR = Math.min(window.devicePixelRatio || 1, 1.75);

  const FOREST = '#0D7555', FOREST2 = '#065F46', SAGE = '#A7D8C4', CREAM = '#FAF8F4';
  const AMBER = '#E8A23D', GLOW = '#F2C078', BARK = '#6B4F3A', GRASS = '#3E7D5F', ROOF = '#7A3B2E';
  const HEAD = '#E9DCC5';
  const BODY_COLORS = ['#065F46', '#0D7555', '#059669', '#7A3B2E', '#46618A'];
  const std = (color: string) => new THREE.MeshStandardMaterial({ color, flatShading: true });

  // ── Reusable low-poly pieces ──
  function makeFigure(scale = 1, bodyColor = FOREST2) {
    const g = new THREE.Group();
    // Rounded capsule torso + warm head reads as a person, not a cone.
    const torso = new THREE.Mesh(new THREE.CapsuleGeometry(0.13, 0.3, 4, 10), std(bodyColor));
    torso.position.y = 0.32;
    const head = new THREE.Mesh(new THREE.SphereGeometry(0.115, 14, 14), std(HEAD));
    head.position.y = 0.62;
    g.add(torso, head);
    g.scale.setScalar(scale);
    return g;
  }
  function makeTree(scale = 1) {
    const g = new THREE.Group();
    const trunk = new THREE.Mesh(new THREE.CylinderGeometry(0.07, 0.1, 0.55, 6), std(BARK));
    trunk.position.y = 0.27;
    // Two-tuft crown in brighter sage-emerald so it reads on both the dark
    // forest section and the light cards.
    const crown = new THREE.Group();
    const c1 = new THREE.Mesh(new THREE.IcosahedronGeometry(0.42, 0), std('#3DA882'));
    c1.position.y = 0.8;
    const c2 = new THREE.Mesh(new THREE.IcosahedronGeometry(0.27, 0), std('#63CBA2'));
    c2.position.set(0.13, 1.05, 0.05);
    crown.add(c1, c2);
    g.add(trunk, crown);
    g.scale.setScalar(scale);
    return g;
  }
  function makeCabin() {
    const g = new THREE.Group();
    const wall = new THREE.Mesh(new THREE.BoxGeometry(0.5, 0.4, 0.5), std(CREAM));
    wall.position.y = 0.2;
    const roof = new THREE.Mesh(new THREE.ConeGeometry(0.43, 0.3, 4), std(ROOF));
    roof.position.y = 0.56; roof.rotation.y = Math.PI / 4;
    // Front face (+z): a door centred at the base with a lit window either side.
    const door = new THREE.Mesh(new THREE.PlaneGeometry(0.15, 0.24), std('#5C3A2E'));
    door.position.set(0, 0.12, 0.251);
    const winMat = new THREE.MeshBasicMaterial({ color: GLOW });
    const w1 = new THREE.Mesh(new THREE.PlaneGeometry(0.1, 0.1), winMat); w1.position.set(-0.15, 0.28, 0.251);
    const w2 = new THREE.Mesh(new THREE.PlaneGeometry(0.1, 0.1), winMat); w2.position.set(0.15, 0.28, 0.251);
    g.add(wall, roof, door, w1, w2);
    return g;
  }
  // Low-poly bee: amber body with dark stripe bands, a dark head and two pale wings. Faces +z.
  function makeBee() {
    const g = new THREE.Group();
    const body = new THREE.Mesh(new THREE.SphereGeometry(0.07, 8, 8), std('#E8A23D')); body.scale.set(1, 0.85, 1.35); g.add(body);
    const head = new THREE.Mesh(new THREE.SphereGeometry(0.045, 8, 8), std('#2A2018')); head.position.z = 0.1; g.add(head);
    for (const z of [0.0, -0.05]) { const band = new THREE.Mesh(new THREE.TorusGeometry(0.066, 0.018, 6, 14), std('#2A2018')); band.position.z = z; g.add(band); }
    const wingMat = new THREE.MeshBasicMaterial({ color: '#FFFFFF', transparent: true, opacity: 0.5, side: THREE.DoubleSide });
    const w1 = new THREE.Mesh(new THREE.CircleGeometry(0.07, 8), wingMat); w1.scale.set(1, 0.45, 1); w1.position.set(0.055, 0.05, 0); w1.rotation.z = 0.6; g.add(w1);
    const w2 = new THREE.Mesh(new THREE.CircleGeometry(0.07, 8), wingMat); w2.scale.set(1, 0.45, 1); w2.position.set(-0.055, 0.05, 0); w2.rotation.z = -0.6; g.add(w2);
    g.scale.setScalar(0.5);
    return g;
  }
  // A flattened tube along a Catmull-Rom curve = a curvy path hugging the ground.
  function pathRibbon(pts: THREE.Vector3[], color: string) {
    const curve = new THREE.CatmullRomCurve3(pts);
    const m = new THREE.Mesh(new THREE.TubeGeometry(curve, 40, 0.07, 6, false), std(color));
    m.scale.y = 0.18; m.position.y = 0.012;
    return m;
  }
  function fire(group: THREE.Group, y = 0.25) {
    const flame = new THREE.Mesh(new THREE.ConeGeometry(0.22, 0.5, 6), new THREE.MeshBasicMaterial({ color: AMBER }));
    flame.position.y = y;
    const glow = new THREE.Mesh(new THREE.SphereGeometry(0.6, 14, 14), new THREE.MeshBasicMaterial({ color: GLOW, transparent: true, opacity: 0.18 }));
    glow.position.y = y;
    group.add(flame, glow);
    return (t: number) => { flame.scale.set(1, 1 + Math.sin(t * 3) * 0.09, 1); glow.scale.setScalar(1 + Math.sin(t * 2.2) * 0.06); };
  }

  // ── Builders: each returns { update, camera } ──
  function buildRing(group: THREE.Group, small: boolean) {
    const N = small ? 7 : 9, R = 1.55;
    const figs: { f: THREE.Group; ph: number }[] = [];
    for (let i = 0; i < N; i++) {
      const a = (i / N) * Math.PI * 2;
      const f = makeFigure(1);
      f.position.set(Math.cos(a) * R, 0, Math.sin(a) * R);
      f.rotation.y = -a + Math.PI / 2;
      group.add(f); figs.push({ f, ph: i });
    }
    const fireUp = fire(group, 0.25);
    group.position.y = -0.55;
    return {
      update: (t: number) => { group.rotation.y = t * 0.12; figs.forEach(({ f, ph }) => { f.position.y = Math.sin(t * 1.4 + ph) * 0.045; }); fireUp(t); },
      camera: { pos: [0, 2.6, 5.2] as const, look: [0, 0, 0] as const },
    };
  }

  function buildTree(group: THREE.Group) {
    const tree = makeTree(2.1); group.add(tree);
    const canopy = tree.children[1] as THREE.Mesh;
    const flies: { m: THREE.Mesh; r: number; a: number; y: number; sp: number }[] = [];
    for (let i = 0; i < 8; i++) {
      const m = new THREE.Mesh(new THREE.SphereGeometry(0.035, 6, 6), new THREE.MeshBasicMaterial({ color: GLOW, transparent: true }));
      group.add(m);
      flies.push({ m, r: 1.1 + Math.random() * 1.1, a: Math.random() * 6.28, y: 0.8 + Math.random() * 1.9, sp: 0.3 + Math.random() * 0.4 });
    }
    group.position.y = -1.25;
    return {
      update: (t: number) => {
        canopy.rotation.z = Math.sin(t * 0.7) * 0.06; canopy.position.x = Math.sin(t * 0.7) * 0.03;
        flies.forEach((o) => {
          o.m.position.set(Math.cos(o.a + t * o.sp) * o.r, o.y + Math.sin(t * o.sp * 2 + o.a) * 0.18, Math.sin(o.a + t * o.sp) * o.r);
          (o.m.material as THREE.MeshBasicMaterial).opacity = 0.45 + Math.sin(t * 3 + o.a) * 0.45;
        });
      },
      camera: { pos: [0, 0.95, 5.9] as const, look: [0, 0.2, 0] as const },
    };
  }

  function buildVillage(group: THREE.Group, small: boolean) {
    const green = new THREE.Mesh(new THREE.CircleGeometry(1.8, 30), std(GRASS));
    green.rotation.x = -Math.PI / 2; group.add(green);
    const n = small ? 3 : 4;
    for (let i = 0; i < n; i++) {
      const a = (i / n) * Math.PI * 2 + 0.4;
      const c = makeCabin(); c.position.set(Math.cos(a) * 1.3, 0, Math.sin(a) * 1.3); c.rotation.y = -a - Math.PI / 2; c.scale.setScalar(0.9);
      group.add(c);
    }
    // Curvy paths linking each door to its neighbours, bowing toward the green.
    const doorR = 1.05, ctrlR = 0.6;
    for (let i = 0; i < n; i++) {
      const a0 = (i / n) * Math.PI * 2 + 0.4;
      const a1 = ((i + 1) / n) * Math.PI * 2 + 0.4;
      const am = a0 + Math.PI / n;
      const p0 = new THREE.Vector3(Math.cos(a0) * doorR, 0, Math.sin(a0) * doorR);
      const pc = new THREE.Vector3(Math.cos(am) * ctrlR, 0, Math.sin(am) * ctrlR);
      const p1 = new THREE.Vector3(Math.cos(a1) * doorR, 0, Math.sin(a1) * doorR);
      group.add(pathRibbon([p0, pc, p1], '#CBB68C'));
    }
    // Trees sit in the gaps between houses (same ring), clearing the inner
    // green so the inward-facing doors are visible.
    for (let i = 0; i < n; i++) { const a = (i / n) * Math.PI * 2 + 0.4 + Math.PI / n; const tr = makeTree(0.62); tr.position.set(Math.cos(a) * 1.3, 0, Math.sin(a) * 1.3); group.add(tr); }
    group.position.y = -0.6;
    return {
      update: (t: number) => { group.rotation.y = t * 0.1; },
      camera: { pos: [0, 3.0, 4.3] as const, look: [0, -0.2, 0] as const },
    };
  }

  // Distributed network: several small settlements linked by paths = a network of communities.
  function buildNetwork(group: THREE.Group, small: boolean) {
    const n = small ? 3 : 4, R = 1.55;
    const centers: THREE.Vector3[] = [];
    for (let i = 0; i < n; i++) {
      const a = (i / n) * Math.PI * 2 + 0.5;
      const cx = Math.cos(a) * R, cz = Math.sin(a) * R;
      centers.push(new THREE.Vector3(cx, 0, cz));
      const s = new THREE.Group(); s.position.set(cx, 0, cz);
      const disc = new THREE.Mesh(new THREE.CircleGeometry(0.55, 22), std(GRASS)); disc.rotation.x = -Math.PI / 2; s.add(disc);
      const cab = makeCabin(); cab.scale.setScalar(0.4); cab.position.set(-0.1, 0, 0.06); cab.rotation.y = -a + Math.PI; s.add(cab);
      const tr = makeTree(0.32); tr.position.set(0.22, 0, -0.12); s.add(tr);
      group.add(s);
    }
    for (let i = 0; i < centers.length; i++)
      for (let j = i + 1; j < centers.length; j++)
        group.add(pathRibbon([centers[i].clone(), centers[j].clone()], '#CBB68C'));
    group.position.y = -0.4;
    return { update: (t: number) => { group.rotation.y = t * 0.1; }, camera: { pos: [0, 3.4, 4.9] as const, look: [0, -0.15, 0] as const } };
  }

  // Communal gathering hall (roundhouse), the shared/cooperative space.
  function buildHall(group: THREE.Group) {
    const base = new THREE.Mesh(new THREE.CircleGeometry(1.7, 28), std(GRASS)); base.rotation.x = -Math.PI / 2; group.add(base);
    const body = new THREE.Mesh(new THREE.CylinderGeometry(0.92, 0.98, 0.7, 12), std(CREAM)); body.position.y = 0.35; group.add(body);
    const roof = new THREE.Mesh(new THREE.ConeGeometry(1.2, 0.75, 12), std(ROOF)); roof.position.y = 1.05; group.add(roof);
    const door = new THREE.Mesh(new THREE.PlaneGeometry(0.24, 0.44), std('#5C3A2E')); door.position.set(0.95, 0.22, 0); door.lookAt(3, 0.22, 0); group.add(door);
    const winMat = new THREE.MeshBasicMaterial({ color: GLOW });
    for (let i = 0; i < 6; i++) {
      const a = (i / 6) * Math.PI * 2 + 0.5;
      const w = new THREE.Mesh(new THREE.PlaneGeometry(0.16, 0.18), winMat);
      w.position.set(Math.cos(a) * 0.94, 0.4, Math.sin(a) * 0.94); w.lookAt(Math.cos(a) * 3, 0.4, Math.sin(a) * 3);
      group.add(w);
    }
    group.position.y = -0.55;
    return { update: (t: number) => { group.rotation.y = t * 0.12; }, camera: { pos: [0, 1.6, 5.0] as const, look: [0, 0.3, 0] as const } };
  }

  // Beehive (straw skep), the historic symbol of the cooperative movement, with drifting bees.
  function buildBeehive(group: THREE.Group) {
    const profile = [[0.0, 0], [0.96, 0.0], [0.93, 0.22], [0.85, 0.45], [0.72, 0.68], [0.52, 0.9], [0.28, 1.08], [0.0, 1.18]]
      .map(([x, y]) => new THREE.Vector2(x, y));
    group.add(new THREE.Mesh(new THREE.LatheGeometry(profile, 18), std('#D9A441')));
    const coilMat = std('#BE812B');
    for (const [r, y] of [[0.92, 0.12], [0.82, 0.34], [0.66, 0.58], [0.45, 0.82], [0.22, 1.0]]) {
      const t = new THREE.Mesh(new THREE.TorusGeometry(r, 0.035, 8, 22), coilMat);
      t.rotation.x = Math.PI / 2; t.position.y = y; group.add(t);
    }
    const door = new THREE.Mesh(new THREE.PlaneGeometry(0.22, 0.16), std('#3A2A14')); door.position.set(0, 0.16, 0.95); group.add(door);
    const bees: { m: THREE.Group; r: number; a: number; y: number; sp: number }[] = [];
    for (let i = 0; i < 3; i++) {
      const m = makeBee(); group.add(m);
      bees.push({ m, r: 1.15 + Math.random() * 0.45, a: Math.random() * 6.28, y: 0.4 + Math.random() * 0.7, sp: 0.8 + Math.random() * 0.6 });
    }
    group.position.y = -0.55;
    return {
      update: (t: number) => {
        group.rotation.y = t * 0.1;
        bees.forEach((o) => {
          const ang = o.a + t * o.sp;
          o.m.position.set(Math.cos(ang) * o.r, o.y + Math.sin(t * o.sp * 1.7 + o.a) * 0.12, Math.sin(ang) * o.r);
          o.m.rotation.y = -ang;
        });
      },
      camera: { pos: [0, 1.0, 4.4] as const, look: [0, 0.45, 0] as const },
    };
  }

  // Signpost at a fork in the path, "choose your way", the start of a journey.
  function buildSignpost(group: THREE.Group) {
    const base = new THREE.Mesh(new THREE.CircleGeometry(1.6, 26), std(GRASS)); base.rotation.x = -Math.PI / 2; group.add(base);
    const O = new THREE.Vector3(0, 0, 0); // fork + post on the rotation axis so it stays upright
    group.add(pathRibbon([new THREE.Vector3(0, 0, 1.45), O], '#CBB68C'));
    group.add(pathRibbon([O, new THREE.Vector3(-1.35, 0, 0.1)], '#CBB68C'));
    group.add(pathRibbon([O, new THREE.Vector3(1.35, 0, 0.1)], '#CBB68C'));
    const post = new THREE.Mesh(new THREE.CylinderGeometry(0.06, 0.075, 1.4, 8), std(BARK)); post.position.set(0, 0.7, 0); group.add(post);
    const cap = new THREE.Mesh(new THREE.SphereGeometry(0.085, 8, 8), std(BARK)); cap.position.set(0, 1.42, 0); group.add(cap);
    // two fingerboards at different heights pointing straight left and right
    const board = (y: number, ang: number) => {
      const arm = new THREE.Group(); arm.position.set(0, y, 0); arm.rotation.y = ang;
      const b = new THREE.Mesh(new THREE.BoxGeometry(0.62, 0.15, 0.05), std('#9C7B52')); b.position.x = 0.34; arm.add(b);
      const tip = new THREE.Mesh(new THREE.CylinderGeometry(0.105, 0.105, 0.05, 3), std('#9C7B52')); tip.rotation.x = Math.PI / 2; tip.rotation.y = Math.PI; tip.position.set(0.69, 0, 0); arm.add(tip);
      group.add(arm);
    };
    board(1.18, Math.PI);
    board(0.95, 0);
    group.position.y = -0.5;
    return { update: (t: number) => { group.rotation.y = Math.sin(t * 0.18) * 0.22; }, camera: { pos: [0, 1.05, 4.2] as const, look: [0, 0.15, 0] as const } };
  }

  // Watermill: a mill house beside a turning water wheel dipping into a pool.
  function buildWatermill(group: THREE.Group) {
    const water = new THREE.Mesh(new THREE.CircleGeometry(0.78, 24), std('#3E7CB8')); water.rotation.x = -Math.PI / 2; water.position.set(0, 0.02, 0.12); group.add(water);
    // plain mill house (no door/windows); wall top sits above the wheel's top
    const mill = new THREE.Group();
    const wall = new THREE.Mesh(new THREE.BoxGeometry(1.5, 1.25, 1.0), std(CREAM)); wall.position.y = 0.625; mill.add(wall);
    const roof = new THREE.Mesh(new THREE.ConeGeometry(1.0, 0.62, 4), std(ROOF)); roof.rotation.y = Math.PI / 4; roof.scale.set(1.16, 1, 0.8); roof.position.y = 1.56; mill.add(roof);
    mill.position.set(0, 0, -0.4); group.add(mill);
    // water wheel centred on the wall, faces the camera (axle along Z), spins
    const wheel = new THREE.Group(); wheel.position.set(0, 0.55, 0.12); wheel.scale.setScalar(0.85);
    const wood = std(BARK), plank = std('#9C7B52');
    wheel.add(new THREE.Mesh(new THREE.TorusGeometry(0.62, 0.055, 8, 26), wood));
    wheel.add(new THREE.Mesh(new THREE.TorusGeometry(0.44, 0.045, 8, 26), wood));
    const hub = new THREE.Mesh(new THREE.CylinderGeometry(0.08, 0.08, 0.42, 10), wood); hub.rotation.x = Math.PI / 2; wheel.add(hub);
    const N = 8;
    for (let i = 0; i < N; i++) {
      const a = (i / N) * Math.PI * 2;
      const spoke = new THREE.Mesh(new THREE.BoxGeometry(0.045, 0.64, 0.045), wood);
      spoke.position.set(Math.cos(a) * 0.3, Math.sin(a) * 0.3, 0); spoke.rotation.z = a - Math.PI / 2; wheel.add(spoke);
      const pad = new THREE.Mesh(new THREE.BoxGeometry(0.06, 0.22, 0.34), plank);
      pad.position.set(Math.cos(a) * 0.62, Math.sin(a) * 0.62, 0); pad.rotation.z = a; wheel.add(pad);
    }
    group.add(wheel);
    // axle linking the wheel hub into the mill wall
    const axle = new THREE.Mesh(new THREE.CylinderGeometry(0.05, 0.05, 0.7, 8), std(BARK)); axle.rotation.x = Math.PI / 2; axle.position.set(0, 0.55, -0.1); group.add(axle);
    group.position.y = -0.55;
    return { update: (t: number) => { wheel.rotation.z = -t * 0.6; }, camera: { pos: [0, 1.1, 5.0] as const, look: [0, 0.4, 0] as const } };
  }

  // Winding path through rolling hills, calm, hopeful, "the journey".
  function buildPath(group: THREE.Group) {
    const ground = new THREE.Mesh(new THREE.CircleGeometry(1.9, 30), std('#3E7D5F')); ground.rotation.x = -Math.PI / 2; group.add(ground);
    const dome = (x: number, z: number, sx: number, sy: number, sz: number, c: string) => {
      const m = new THREE.Mesh(new THREE.SphereGeometry(0.6, 14, 8, 0, Math.PI * 2, 0, Math.PI / 2), std(c));
      m.scale.set(sx, sy, sz); m.position.set(x, 0, z); group.add(m);
    };
    dome(0.15, -1.25, 2.0, 0.78, 1.4, '#27654C'); // far (darker = aerial perspective)
    dome(-0.85, -0.7, 1.7, 0.62, 1.3, '#2F6E54');
    dome(0.9, -0.45, 1.5, 0.56, 1.2, '#37805F');
    const pts = [[0.15, 0.02, 1.7], [-0.5, 0.05, 0.9], [0.4, 0.09, 0.05], [-0.15, 0.16, -0.65], [0.2, 0.26, -1.2]]
      .map((p) => new THREE.Vector3(p[0], p[1], p[2]));
    const path = new THREE.Mesh(new THREE.TubeGeometry(new THREE.CatmullRomCurve3(pts), 48, 0.11, 6, false), std('#CBB68C'));
    path.scale.y = 0.25; path.position.y = 0.02; group.add(path);
    const t1 = makeTree(0.5); t1.position.set(-0.95, 0.18, -0.7); group.add(t1);
    const t2 = makeTree(0.42); t2.position.set(0.95, 0.16, -0.5); group.add(t2);
    group.position.y = -0.45;
    return { update: (t: number) => { group.rotation.y = Math.sin(t * 0.12) * 0.1; }, camera: { pos: [0, 1.5, 4.7] as const, look: [0, 0.25, 0] as const } };
  }

  // Arched footbridge over a pond, calm, "crossing over".
  function buildBridge(group: THREE.Group) {
    const water = new THREE.Mesh(new THREE.CircleGeometry(1.7, 30), std('#3E7CB8')); water.rotation.x = -Math.PI / 2; group.add(water);
    const bank = (x: number) => { const m = new THREE.Mesh(new THREE.SphereGeometry(0.55, 12, 8, 0, Math.PI * 2, 0, Math.PI / 2), std('#37805F')); m.scale.set(1.0, 0.4, 1.4); m.position.set(x, 0, 0); group.add(m); };
    bank(-1.5); bank(1.5);
    const arc = [[-1.45, 0.04, 0], [-0.75, 0.42, 0], [0, 0.62, 0], [0.75, 0.42, 0], [1.45, 0.04, 0]].map((p) => new THREE.Vector3(p[0], p[1], p[2]));
    const curve = new THREE.CatmullRomCurve3(arc);
    const wood = std('#9C7B52');
    // deck planks following the arch
    const N = 15;
    for (let i = 0; i <= N; i++) {
      const u = i / N, pt = curve.getPointAt(u), tan = curve.getTangentAt(u);
      const plank = new THREE.Mesh(new THREE.BoxGeometry(0.26, 0.06, 0.52), wood);
      plank.position.copy(pt); plank.rotation.z = Math.atan2(tan.y, tan.x); group.add(plank);
    }
    // railings + posts
    for (const z of [0.25, -0.25]) {
      const rail = new THREE.Mesh(new THREE.TubeGeometry(new THREE.CatmullRomCurve3(arc.map((v) => new THREE.Vector3(v.x, v.y + 0.24, z))), 40, 0.025, 6, false), std(BARK));
      group.add(rail);
    }
    for (const u of [0.1, 0.3, 0.5, 0.7, 0.9]) {
      const pt = curve.getPointAt(u);
      for (const z of [0.25, -0.25]) { const post = new THREE.Mesh(new THREE.CylinderGeometry(0.022, 0.022, 0.26, 6), std(BARK)); post.position.set(pt.x, pt.y + 0.12, z); group.add(post); }
    }
    // a few drifting lily pads
    const pads: { p: THREE.Mesh; base: number; sp: number }[] = [];
    for (let i = 0; i < 3; i++) {
      const pad = new THREE.Mesh(new THREE.CircleGeometry(0.14, 10), std('#3E7D5F')); pad.rotation.x = -Math.PI / 2;
      pad.position.set(-0.8 + i * 0.8, 0.03, i % 2 ? 0.8 : -0.75); group.add(pad);
      pads.push({ p: pad, base: pad.position.x, sp: 0.07 + i * 0.02 });
    }
    group.position.y = -0.35;
    return {
      update: (t: number) => { group.rotation.y = t * 0.15; pads.forEach((o, i) => { o.p.position.x = o.base + Math.sin(t * o.sp + i) * 0.14; }); },
      camera: { pos: [0, 1.15, 4.7] as const, look: [0, 0.22, 0] as const },
    };
  }

  function buildNodes(group: THREE.Group, small: boolean) {
    const N = small ? 26 : 42, R = 1.6;
    const phi = Math.PI * (3 - Math.sqrt(5));
    const pts: THREE.Vector3[] = [];
    for (let i = 0; i < N; i++) { const y = 1 - (i / (N - 1)) * 2; const r = Math.sqrt(1 - y * y); const t = phi * i; pts.push(new THREE.Vector3(Math.cos(t) * r, y, Math.sin(t) * r).multiplyScalar(R)); }
    const dotGeo = new THREE.SphereGeometry(0.055, 12, 12); const dotMat = new THREE.MeshBasicMaterial({ color: FOREST });
    for (const p of pts) { const m = new THREE.Mesh(dotGeo, dotMat); m.position.copy(p); group.add(m); }
    const lp: number[] = [];
    for (let i = 0; i < pts.length; i++) { const ns = pts.map((q, j) => ({ j, d: pts[i].distanceTo(q) })).filter((o) => o.j !== i).sort((a, b) => a.d - b.d).slice(0, 2); for (const { j } of ns) lp.push(pts[i].x, pts[i].y, pts[i].z, pts[j].x, pts[j].y, pts[j].z); }
    const lg = new THREE.BufferGeometry(); lg.setAttribute('position', new THREE.Float32BufferAttribute(lp, 3));
    group.add(new THREE.LineSegments(lg, new THREE.LineBasicMaterial({ color: SAGE, transparent: true, opacity: 0.5 })));
    return { update: (t: number) => { group.rotation.y = t * 0.18; group.rotation.x = Math.sin(t * 0.12) * 0.12; }, camera: { pos: [0, 0, 6] as const, look: [0, 0, 0] as const } };
  }

  function buildHearth(group: THREE.Group) {
    const fireUp = fire(group, 0.4);
    for (let i = 0; i < 5; i++) { const log = new THREE.Mesh(new THREE.CylinderGeometry(0.09, 0.09, 1.4, 8), std(FOREST)); log.rotation.z = Math.PI / 2; log.rotation.y = (i / 5) * Math.PI; log.position.y = -0.5; group.add(log); }
    return { update: (t: number) => { group.rotation.y = t * 0.15; fireUp(t); }, camera: { pos: [0, 0, 6] as const, look: [0, 0, 0] as const } };
  }

  function init(el: HTMLElement) {
    const mount = el.querySelector<HTMLElement>('.three-object__mount');
    if (!mount) return;
    let renderer: THREE.WebGLRenderer;
    try { renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true, powerPreference: 'low-power' }); } catch (e) { return; }
    const w = mount.clientWidth || 400, h = mount.clientHeight || 400;
    renderer.setPixelRatio(DPR); renderer.setSize(w, h); mount.appendChild(renderer.domElement);

    const scene = new THREE.Scene();
    scene.add(new THREE.AmbientLight(0xffffff, 0.9));
    const key = new THREE.DirectionalLight(0xfff2dd, 1.1); key.position.set(3, 5, 4); scene.add(key);
    const camera = new THREE.PerspectiveCamera(42, w / h, 0.1, 100);
    const group = new THREE.Group(); scene.add(group);

    const small = window.matchMedia('(max-width: 700px)').matches;
    const type = el.getAttribute('data-three');
    const builders: Record<string, () => any> = {
      ring: () => buildRing(group, small), tree: () => buildTree(group), village: () => buildVillage(group, small),
      network: () => buildNetwork(group, small), hall: () => buildHall(group), beehive: () => buildBeehive(group), signpost: () => buildSignpost(group), watermill: () => buildWatermill(group), path: () => buildPath(group), bridge: () => buildBridge(group),
      nodes: () => buildNodes(group, small), hearth: () => buildHearth(group),
    };
    const built = (builders[type || 'ring'] || builders.ring)();
    const update = built.update;
    camera.position.set(...built.camera.pos); camera.lookAt(new THREE.Vector3(...built.camera.look));
    el.classList.add('is-live');

    function resize() { const cw = mount!.clientWidth, ch = mount!.clientHeight; if (!cw || !ch) return; camera.aspect = cw / ch; camera.updateProjectionMatrix(); renderer.setSize(cw, ch); }
    window.addEventListener('resize', () => requestAnimationFrame(resize), { passive: true });

    const clock = new THREE.Clock();
    let raf = 0, running = false;
    function frame() { update(clock.getElapsedTime()); renderer.render(scene, camera); raf = requestAnimationFrame(frame); }
    function start() { if (!running) { running = true; clock.start(); raf = requestAnimationFrame(frame); } }
    function stop() { running = false; cancelAnimationFrame(raf); }

    if (reduced) { update(0.8); renderer.render(scene, camera); }
    else {
      const io = new IntersectionObserver((es) => { for (const e of es) e.isIntersecting ? start() : stop(); }, { threshold: 0.05 });
      io.observe(el);
      document.addEventListener('visibilitychange', () => { document.hidden ? stop() : start(); });
    }
  }

  function boot() { document.querySelectorAll<HTMLElement>('.three-object[data-three]').forEach((el) => { if (!el.dataset.inited) { el.dataset.inited = '1'; init(el); } }); }
  if (document.readyState !== 'loading') boot(); else document.addEventListener('DOMContentLoaded', boot);
</script>
