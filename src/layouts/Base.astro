---
import '../styles/theme.css';
const { title = 'Distributed Republic', description = 'Building technologically advanced, networked communities for a different way of living.', noindex = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og.png', Astro.site).href;
const nav = [
  { href: '/', label: 'Home' },
  { href: '/about/', label: 'About' },
  { href: '/events/', label: 'Events' },
  { href: '/blog/', label: 'Blog' },
  { href: '/resources/', label: 'Resources' },
  { href: '/contact/', label: 'Contact' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta property="og:site_name" content="Distributed Republic" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/axs/axs-widget.css" />
</head>
<body>
  <header class="site-header">
    <div class="container nav">
      <a class="brand" href="/" aria-label="Distributed Republic home">
        <img src="/dr-mark.svg" alt="" width="34" height="34" />
        <b>Distributed Republic</b>
      </a>
      <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">&#9776;</button>
      <nav class="nav-links" aria-label="Primary">
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      </nav>
    </div>
  </header>

  <main id="main">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="foot-grid">
        <div>
          <a class="brand" href="/" style="margin-bottom:14px">
            <img src="/dr-mark.svg" alt="" width="30" height="30" style="filter:brightness(0) invert(1)" />
            <b style="color:var(--cream)">Distributed Republic</b>
          </a>
          <p style="color:var(--sage-soft);max-width:42ch">Networked communities under an anarchic-agreements model. Campus, Curation, Rituals, Contribution.</p>
        </div>
        <div>
          <h3 style="color:var(--cream);font-size:18px">Explore</h3>
          {nav.slice(1).map((n) => <div style="margin:6px 0"><a href={n.href}>{n.label}</a></div>)}
        </div>
        <div>
          <h3 style="color:var(--cream);font-size:18px">Get involved</h3>
          <div style="margin:6px 0"><a href="/contact/">Contact us</a></div>
          <div style="margin:6px 0"><a href="/events/">Upcoming events</a></div>
        </div>
      </div>
      <div class="foot-bottom">© 2026 Distributed Republic. Community living.</div>
    </div>
  </footer>

  <!-- Replay the entry splash. On home, reopens it; elsewhere, navigates home and opens. -->
  <button id="dr-splash-btn" class="dr-splash-btn" type="button" aria-label="Replay the intro" title="Replay the intro">
    <svg viewBox="0 0 24 24" fill="#FAF8F4" fill-rule="evenodd" aria-hidden="true">
      <path d="M12 3l9 8h-2v9H5v-9H3l9-8z M10.4 13v6h3.2v-6h-3.2z" />
    </svg>
  </button>
  <style>
    .dr-splash-btn {
      position: fixed; right: 20px; bottom: 88px; z-index: 99999;
      width: 52px; height: 52px; border-radius: 16px; border: 0;
      background: #065F46; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 6px 20px rgba(0,0,0,0.18); transition: background .15s ease, transform .15s ease;
    }
    .dr-splash-btn:hover, .dr-splash-btn:focus-visible { background: #FAF8F4; transform: translateY(-1px); outline: none; }
    .dr-splash-btn:hover svg path, .dr-splash-btn:focus-visible svg path { fill: #065F46; }
    .dr-splash-btn svg { width: 26px; height: 26px; }
    .dr-splash-btn svg path { transition: fill .15s ease; }
  </style>
  <script>
    document.getElementById('dr-splash-btn')?.addEventListener('click', () => {
      if (document.getElementById('dr-splash')) window.dispatchEvent(new Event('dr-open-splash'));
      else window.location.href = '/#open-splash';
    });
  </script>

  <script src="/axs/axs-widget.js" defer></script>
  <script>
    const t = document.querySelector('.nav-toggle');
    const links = document.querySelector('.nav-links');
    t?.addEventListener('click', () => {
      const open = links?.classList.toggle('open');
      t.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
  </script>
</body>
</html>
