---
import Base from '../layouts/Base.astro';
import ThreeObject from '../components/ThreeObject.astro';
---
<Base title="About — Distributed Republic">
  <section class="container section">
    <p class="eyebrow">About</p>
    <h1>The people and the idea.</h1>
    <p class="lead" style="font-size:20px;max-width:70ch">Distributed Republic is a values-led project, not a product. It is the work of Jamie Bykov-Brett and his partner, exploring how to build and join communities that live well together.</p>
  </section>

  <section class="section section--cream2">
    <div class="container grid grid-2" style="align-items:start">
      <div>
        <p class="eyebrow">The why</p>
        <h2>The people</h2>
        <p>We believe a different way of living is possible: more shared, more connected, and more deliberate about the agreements we make with one another. This site is how we find the people who feel the same. [Placeholder copy — Emi and Jamie will write the real story.]</p>
      </div>
      <div>
        <p class="eyebrow">The idea</p>
        <h2>Networked communities</h2>
        <p>Communities held together by explicit, mutually agreed constitutions rather than top-down control. We take inspiration from the cooperative tradition, including Mondragon, where member ownership and federation scale without losing local character. [Placeholder copy.]</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container hero" style="padding:0">
      <div>
        <p class="eyebrow">Governance</p>
        <h2>Anarchic agreements.</h2>
        <p>Not rules handed down, but a constitution written together. We are exploring a cooperative structure, member-owned and one-member-one-vote, as the vehicle that holds the commons and the community. [Placeholder copy.]</p>
      </div>
      <ThreeObject type="nodes" height="380px" label="Connected nodes representing a network of communities bound by shared agreements" />
    </div>
  </section>
</Base>
