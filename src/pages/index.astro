      new THREE.MeshStandardMaterial({ color: 0x8FC8D8, flatShading: true, roughness: 0.3 }));
    pool.rotation.x = -Math.PI / 2;
    pool.position.set(-13.6, 0.09, -5.8);
    gMill.add(pool);
    for (let i = 0; i < 7; i++) {
      const a = (i / 7) * Math.PI * 2 + 0.5;
      const px = -13.6 + Math.cos(a) * 2.0, pz = -5.8 + Math.sin(a) * 2.0;
      const st = new THREE.Mesh(new THREE.DodecahedronGeometry(0.15 + rand() * 0.1, 0),
        new THREE.MeshStandardMaterial({ color: 0xC8BCA2, flatShading: true, roughness: 1 }));
      st.position.set(px, hAt(px, pz) + 0.12, pz);
      gMill.add(st);
    }
    // waterwheel: its plane runs along the flow, dipping into the water
