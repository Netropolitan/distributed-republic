    // the river: from the spring pool, past the mill, into the lake
    const sPts = RIVER_PTS.map(([x, z]) => new THREE.Vector3(x, 0, z));
    const sCurve = new THREE.CatmullRomCurve3(sPts);
    const SEGS = 80;
    const rPos = [], rIdx = [];
    for (let i = 0; i <= SEGS; i++) {
      const u = i / SEGS;
      const p = sCurve.getPointAt(u);
      const tng = sCurve.getTangentAt(u);
      const nx = -tng.z, nz = tng.x;
      const w = 0.45 + u * 0.45;
      for (const s of [1, -1]) {
        const vx = p.x + nx * w * s, vz = p.z + nz * w * s;
        let vy = hAt(vx, vz) + 0.07;
        // under the pool disc the river sits a touch lower, so the pool laps over it
        const dp = Math.hypot(vx + 13.6, vz + 5.8);
        if (dp < 1.9) vy = Math.min(vy, 0.075);
        rPos.push(vx, vy, vz);
      }
      if (i) { const k = i * 2; rIdx.push(k - 2, k - 1, k, k - 1, k + 1, k); }
    }
    const rGeo = new THREE.BufferGeometry();
    rGeo.setAttribute('position', new THREE.Float32BufferAttribute(rPos, 3));
    rGeo.setIndex(rIdx);
    rGeo.computeVertexNormals();
    const river = new THREE.Mesh(rGeo,
      new THREE.MeshStandardMaterial({ color: 0x8FC8D8, flatShading: true, roughness: 0.3, side: THREE.DoubleSide }));
    gMill.add(river);
    // the spring pool at the source, ringed with stones
