---
import Base from '../layouts/Base.astro';
import ThreeObject from '../components/ThreeObject.astro';
const options = [
  { type: 'ring', name: 'Ring of people', note: 'Figures gathered in a circle around a warm centre. Humanises the commons-ring logo.' },
  { type: 'tree', name: 'Commons tree', note: 'A swaying tree with figures beneath and drifting fireflies. Organic and hopeful.' },
  { type: 'village', name: 'Living homestead', note: 'Cabins around a green with trees and wandering figures. The place we are building.' },
];
---
<Base title="Hero options · Distributed Republic" description="Internal preview of hero objects." noindex={true}>
  <section class="container section">
    <p class="eyebrow">Internal preview</p>
    <h1>Hero object options</h1>
    <p class="lead" style="max-width:64ch">Three community-driven three.js objects to replace the node cluster on the home hero. They are interactive and animate live. Pick one.</p>
    <div class="grid grid-3" style="margin-top:36px">
      {options.map((o) => (
        <div class="card" style="padding:0;overflow:hidden">
          <ThreeObject type={o.type} height="360px" label={o.name} />
          <div style="padding:22px 24px;border-top:1px solid var(--line)">
            <h3 style="margin-bottom:6px">{o.name}</h3>
            <p style="margin-bottom:0;font-size:15px">{o.note}</p>
          </div>
        </div>
      ))}
    </div>
  </section>
</Base>
