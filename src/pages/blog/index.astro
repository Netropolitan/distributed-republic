---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const fmt = (d: Date) => d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
---
<Base title="Blog · Distributed Republic" description="Notes from the journey: thinking out loud about community living, governance, and the places we are exploring.">
  <section class="container section">
    <span class="step-tag">Blog · The network</span>
    <h1>Notes from the journey.</h1>
    <p class="lead" style="max-width:62ch">Thinking out loud about community living, governance, and the places we are exploring.</p>

    <div style="margin-top:32px;max-width:860px">
      {posts.length ? (
        <div class="list">
          {posts.map((post) => (
            <a href={`/blog/${post.id}/`}>
              <span class="when">{fmt(post.data.pubDate)}</span>
              <span><h3>{post.data.title}</h3><p>{post.data.description}</p></span>
              <span class="go">→</span>
            </a>
          ))}
        </div>
      ) : (
        <div class="card" style="text-align:center;padding:56px 28px">
          <h2 style="font-size:clamp(24px,2.4vw,32px)">The first notes are being written</h2>
          <p style="margin:0 auto">Follow along and they will land here soon.</p>
        </div>
      )}
    </div>
  </section>
</Base>
